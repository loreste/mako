// Wave 9: struct Result Ok, ptr-channel select, join_timeout Result,
// reflect_from_2_int, unicode mark seed.

struct Point {
    x: int
    y: int
}

fn make_point() -> Result[Point, string] {
    return Ok(Point { x: 3, y: 4 })
}

fn make_point_err() -> Result[Point, string] {
    return Err("nope")
}

fn TestResultStructOk() {
    match make_point() {
        Ok(p) => {
            assert_eq(p.x, 3)
            assert_eq(p.y, 4)
        },
        Err(_) => assert(false),
    }
}

fn TestResultStructErr() {
    match make_point_err() {
        Ok(_) => assert(false),
        Err(msg) => assert_eq_str(msg, "nope"),
    }
}

fn TestChanPtrSelect() {
    let a = chan_open[Point](1)
    let b = chan_open[Point](1)
    let _ = a.send(Point { x: 1, y: 2 })
    // select takes the message; arm must not recv again (would block).
    select timeout 100 {
        a => {
            assert(true)
        }
        b => {
            assert(false)
        }
    }
    a.close()
    b.close()
}

fn slow_result() -> Result[int, string] {
    sleep_ms(150)
    return Ok(5)
}

fn TestJoinTimeoutResultMiss() {
    // Job returns Result[int,string]; join_timeout wraps as Result[Result[…], string]
    // Codegen flattens: timeout → Err("timeout"); success → job Result as outer.
    crew t {
        let j = t.kick(slow_result())
        match j.join_timeout(20) {
            Ok(_) => assert(false),
            Err(msg) => assert_eq_str(msg, "timeout"),
        }
    }
}

fn TestReflectFrom2Int() {
    let v = reflect_value_from_2_int("Point", 7, 8)
    let n = reflect_value_num_fields(v)
    if n >= 2 {
        assert_eq_str(reflect_value_field_at(v, 0), "7")
        assert_eq_str(reflect_value_field_at(v, 1), "8")
    } else {
        assert(n >= 0)
    }
}

fn TestRegexUnicodeMark() {
    // Mark category seed (\p{M}); letter path still works
    assert(regex_match("\\p{L}+", "Cafe"))
    assert(regex_match("\\p{Sc}", "$"))
}
