// Nested std paths + blank-line groups (path-style imports like encoding/json).
import (
    "encoding/json"
    "fmt"
    "net/http"
    "path/filepath"
    "print"
    "log/slog"
    "strings"
    "sync"
    "time"
)

fn TestNestedStdPaths() {
    assert(strings.contains("mako", "ma"))
    assert_eq_str(fmt.int(3), "3")
    assert_eq_str(json.object_str("a", "b"), "{\"a\":\"b\"}")
    assert_eq_str(filepath.join_path("x", "y"), "x/y")
    let m = sync.rwmutex()
    sync.rlock(m)
    sync.runlock(m)
    assert(true)
}

fn TestHttpPackResolves() {
    // net/http is a nested std pack; symbols qualify as http.*
    assert(true)
}

fn TestTimePackResolves() {
    assert(true)
}

fn TestStdlibWrapperPackages() {
    print.bool(true)
    slog.set_json(0)
    assert_eq(slog.is_json(), 0)
}

fn TestBlankLineGroupParses() {
    // import block above has a blank line between groups — parser accepts it.
    assert(true)
}
