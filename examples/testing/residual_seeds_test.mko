// Residual roadmap seeds: DAP, pprof text, gfx poll, GPU availability,
// hot-reload unwatch, plugin open fail path, ffi abi.

fn TestDapJsonSeed() {
    let init = dap_initialize_response(1)
    assert(str_contains(init, "mako.dap.v1"))
    assert(str_contains(init, "initialize"))
    assert(str_contains(init, "supportsConfigurationDoneRequest"))
    let stop = dap_stopped_event("breakpoint", 1)
    assert(str_contains(stop, "stopped"))
    assert(str_contains(stop, "breakpoint"))
    let thr = dap_threads_response(2)
    assert(str_contains(thr, "threads"))
    let cmd = dap_request_command("{\"command\":\"initialize\",\"type\":\"request\"}")
    assert_eq_str(cmd, "initialize")
    // One-shot request dispatch (stdio adapter seed)
    let resp = dap_handle_request("{\"seq\":7,\"type\":\"request\",\"command\":\"initialize\"}")
    assert(str_contains(resp, "success\":true"))
    assert(str_contains(resp, "initialize"))
    assert_eq(dap_request_seq("{\"seq\":42,\"command\":\"threads\"}"), 42)
    let thr2 = dap_handle_request("{\"seq\":3,\"command\":\"threads\"}")
    assert(str_contains(thr2, "threads"))
    let bad = dap_handle_request("{\"seq\":1,\"command\":\"launch\"}")
    assert(str_contains(bad, "unsupported"))
}

fn TestPprofTextAndThreads() {
    assert_eq(profile_sample_clear(), 1)
    assert_eq(profile_sample_once("a"), 1)
    assert_eq(profile_sample_once("b"), 1)
    let txt = profile_samples_pprof_text()
    assert(str_contains(txt, "mako.profile_pprof_text.v1"))
    assert(str_contains(txt, "tid="))
    assert(profile_sample_thread_count() >= 1)
}

fn TestGfxPollAndBackend() {
    let w = gfx_window_open(320, 240, "seed")
    assert_eq(gfx_poll(w), 0)
    assert_eq_str(gfx_backend_name(), "soft")
    assert_eq(gfx_window_close(w), 0)
}

fn TestGpuBackendAvailability() {
    // Availability is 0 unless MAKO_HAS_METAL/CUDA/VULKAN is enabled.
    assert_eq(gpu_metal_ok(), 0)
    assert_eq(gpu_cuda_ok(), 0)
    assert_eq(gpu_vulkan_ok(), 0)
}

fn TestNetcodeSnapDelta() {
    let a = snap_encode4(1, 2, 3, 4)
    let b = snap_encode4(3, 5, 7, 9)
    let d = snap_diff(a, b)
    assert_eq(snap_get(d, 0), 2)
    assert_eq(snap_get(d, 1), 3)
    let c = snap_apply_delta(a, d)
    assert_eq(snap_get(c, 0), 3)
    assert_eq(snap_get(c, 1), 5)
    assert_eq(netcode_lag_comp_tick(100, 48, 16), 97)
    assert_eq(netcode_interp(0, 1000, 500), 500)
}

fn TestHotReloadUnwatch() {
    let path = "/tmp/mako_hot_unwatch_seed.txt"
    assert_eq(write_file(path, "x"), 0)
    let id = hot_reload_watch(path)
    assert(id >= 0)
    assert(hot_reload_watch_count() >= 1)
    assert_eq(hot_reload_unwatch(path), 1)
    assert_eq(hot_reload_unwatch(path), 0)
}

fn TestPluginOpenMissingAndFfi() {
    // Missing dylib → -1 (host loader seed).
    assert_eq(plugin_open("/tmp/mako_no_such_plugin.so"), -1)
    let abi = ffi_abi_name()
    assert(str_contains(abi, "c-"))
}

fn TestHotReloadSwapAndStamp() {
    let path = "/tmp/mako_hot_stamp_seed.txt"
    assert_eq(write_file(path, "a"), 0)
    let _ = hot_reload_watch(path)
    let s0 = hot_reload_stamp()
    assert_eq(hot_reload_note_swap(), hot_reload_swap_count())
    assert(hot_reload_swap_count() >= 1)
    let js = hot_reload_status_json()
    assert(str_contains(js, "mako.hot_reload.v1"))
    assert(str_contains(js, "swaps"))
    assert(str_contains(js, "stamp"))
    let _ = s0
    assert_eq(hot_reload_unwatch(path), 1)
}

fn TestPredictService() {
    let p = predict_new(100)
    assert_eq(predict_state(p), 100)
    assert_eq(predict_input(p, 5), 105)
    assert_eq(predict_tick(p), 1)
    assert_eq(predict_input(p, 3), 108)
    // Server says auth was 100 at earlier time; re-apply last pending (3)
    assert_eq(predict_reconcile(p, 100), 103)
    assert_eq(predict_free(p), 0)
}

fn TestGfxSoftFramebuffer() {
    let w = gfx_window_open(4, 3, "fb")
    assert_eq(gfx_window_pixels(w), 12)
    assert_eq(gfx_window_fill(w, 255), 0) // 0x000000FF
    assert_eq(gfx_window_get_pixel(w, 0, 0), 255)
    assert_eq(gfx_window_set_pixel(w, 1, 2, 65535), 0)
    assert_eq(gfx_window_get_pixel(w, 1, 2), 65535)
    assert_eq(gfx_window_close(w), 0)
}

fn TestHotReloadPluginMissing() {
    // Missing dylib: open fails; poll/close still safe.
    assert_eq(hot_reload_plugin_watch("/tmp/mako_missing_hot.so"), -1)
    assert_eq(hot_reload_plugin_handle(), -1)
    let _ = hot_reload_plugin_poll() // -1 or 0 depending on path existence
    assert_eq(hot_reload_plugin_close(), 1)
}
