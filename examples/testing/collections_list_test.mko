// List[T] + richer generic collections (int/string specializations).

fn TestListIntAlias() {
    let xs: List[int] = [1, 2, 3]
    assert_eq(len(xs), 3)
    assert_eq(xs[0], 1)
    let ys: List[int] = list_new_int()
    let ys2 = list_push_int(ys, 10)
    let ys3 = list_push_int(ys2, 20)
    assert_eq(list_len_int(ys3), 2)
    assert_eq(list_get_int(ys3, 0), 10)
    assert_eq(list_get_int(ys3, 1), 20)
}

fn TestListPushPop() {
    let mut a = list_new_int()
    a = list_push_int(a, 1)
    a = list_push_int(a, 2)
    a = list_push_int(a, 3)
    assert_eq(stack_peek_int(a), 3)
    a = list_pop_int(a)
    assert_eq(list_popped_int(), 3)
    assert_eq(list_len_int(a), 2)
    assert_eq(stack_peek_int(a), 2)
}

fn TestListInsertRemove() {
    let mut a = list_new_int()
    a = list_push_int(a, 1)
    a = list_push_int(a, 3)
    a = list_insert_int(a, 1, 2)
    assert_eq(list_get_int(a, 0), 1)
    assert_eq(list_get_int(a, 1), 2)
    assert_eq(list_get_int(a, 2), 3)
    a = list_remove_int(a, 1)
    assert_eq(list_len_int(a), 2)
    assert_eq(list_get_int(a, 1), 3)
    a = list_clear_int(a)
    assert_eq(list_len_int(a), 0)
}

fn TestListString() {
    let mut a = list_new_str()
    a = list_push_str(a, "a")
    a = list_push_str(a, "b")
    assert_eq(list_len_str(a), 2)
    assert_eq_str(list_get_str(a, 0), "a")
    a = list_pop_str(a)
    assert_eq_str(list_popped_str(), "b")
    a = list_insert_str(a, 0, "z")
    assert_eq_str(list_get_str(a, 0), "z")
    a = list_remove_str(a, 0)
    assert_eq_str(list_get_str(a, 0), "a")
}

fn TestQueue() {
    let mut q = list_new_int()
    q = list_push_int(q, 10)
    q = list_push_int(q, 20)
    q = list_push_int(q, 30)
    q = queue_pop_int(q)
    assert_eq(queue_popped_int(), 10)
    q = queue_pop_int(q)
    assert_eq(queue_popped_int(), 20)
    assert_eq(list_len_int(q), 1)
    assert_eq(list_get_int(q, 0), 30)
}

fn TestSlicesStr() {
    let rev = slices_reverse_strs(["a", "b", "c"])
    assert_eq_str(rev[0], "c")
    assert_eq_str(rev[2], "a")
    let u = slices_unique_strs(["b", "a", "b", "c", "a"])
    assert_eq(len(u), 3)
    assert_eq(strings_index(["x", "y", "z"], "y"), 1)
    assert_eq(strings_index(["x", "y"], "no"), -1)
    let c = strings_copy(["p", "q"])
    assert_eq(len(c), 2)
    assert_eq_str(c[1], "q")
}

fn TestListAngleBracket() {
    let xs: List<int> = [7, 8]
    assert_eq(len(xs), 2)
    assert_eq(xs[1], 8)
}
