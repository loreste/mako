// Nested Option bags: Option[Option[T]] / Option[Option[chan[T]]] as map values
// Also struct-channel 3-tuples.

struct Point {
    x: int
    y: int
}

fn TestBareNestedOptionInt() {
    let o: Option[Option[int]] = Some(Some(1))
    match o {
        Some(inner) => {
            match inner {
                Some(v) => assert_eq(v, 1),
                None => assert(false),
            }
        },
        None => assert(false),
    }
    let n: Option[Option[int]] = Some(None)
    match n {
        Some(inner) => match inner {
            Some(_) => assert(false),
            None => assert(true),
        },
        None => assert(false),
    }
}

fn TestBareNestedOptionChan() {
    let ch = chan_open[int](1)
    let _ = ch.send(42)
    let o: Option[Option[chan[int]]] = Some(Some(ch))
    match o {
        Some(inner) => match inner {
            Some(c) => {
                assert_eq(c.recv(), 42)
                c.close()
            },
            None => assert(false),
        },
        None => assert(false),
    }
}

fn TestMapOptionOptionInt() {
    let mut m = make(map[string]Option[Option[int]])
    m["a"] = Some(Some(2))
    m["b"] = Some(None)
    m["c"] = None
    match m["a"] {
        Some(inner) => match inner {
            Some(v) => assert_eq(v, 2),
            None => assert(false),
        },
        None => assert(false),
    }
    match m["b"] {
        Some(inner) => match inner {
            Some(_) => assert(false),
            None => assert(true),
        },
        None => assert(false),
    }
    match m["c"] {
        Some(_) => assert(false),
        None => assert(true),
    }
}

fn TestMapOptionOptionChan() {
    let mut m = make(map[string]Option[Option[chan[int]]])
    let ch = chan_open[int](1)
    let _ = ch.send(7)
    m["a"] = Some(Some(ch))
    m["b"] = Some(None)
    match m["a"] {
        Some(inner) => match inner {
            Some(c) => assert_eq(c.recv(), 7),
            None => assert(false),
        },
        None => assert(false),
    }
    match m["b"] {
        Some(inner) => match inner {
            Some(_) => assert(false),
            None => assert(true),
        },
        None => assert(false),
    }
    ch.close()
}

fn TestMapResultOptionChan() {
    let mut m = make(map[int]Result[Option[chan[string]], string])
    let ch = chan_open[string](1)
    let _ = ch.send("hi")
    m[1] = Ok(Some(ch))
    m[2] = Ok(None)
    m[3] = Err("no")
    match m[1] {
        Ok(inner) => match inner {
            Some(c) => assert_eq_str(c.recv(), "hi"),
            None => assert(false),
        },
        Err(_) => assert(false),
    }
    match m[2] {
        Ok(inner) => match inner {
            Some(_) => assert(false),
            None => assert(true),
        },
        Err(_) => assert(false),
    }
    match m[3] {
        Ok(_) => assert(false),
        Err(s) => assert_eq_str(s, "no"),
    }
    ch.close()
}

fn TestMapTupleChanPoint3() {
    let mut m = make(map[string](chan[Point], int, int))
    let ch = chan_open[Point](1)
    let _ = ch.send(Point { x: 3, y: 4 })
    m["p"] = (ch, 1, 2)
    let t = m["p"]
    let c, a, b = t
    assert_eq(a + b, 3)
    let q = c.recv()
    assert_eq(q.x, 3)
    assert_eq(q.y, 4)
    c.close()
}

fn TestMapNestedOptionHelpers() {
    let mut m = make(map[string]Option[Option[int]])
    m["a"] = Some(Some(1))
    m["b"] = Some(Some(2))
    let ks = maps_keys(m)
    assert_eq(len(ks), 2)
    let c = maps_clone(m)
    assert_eq(maps_equal(m, c), 1)
    match c["a"] {
        Some(inner) => match inner {
            Some(v) => assert_eq(v, 1),
            None => assert(false),
        },
        None => assert(false),
    }
}

fn TestMapOptionOptionCommaOk() {
    let mut m = make(map[string]Option[Option[chan[int]]])
    let ch = chan_open[int](1)
    let _ = ch.send(5)
    m["x"] = Some(Some(ch))
    let bag, ok = m["x"]
    assert(ok)
    match bag {
        Some(inner) => match inner {
            Some(c) => assert_eq(c.recv(), 5),
            None => assert(false),
        },
        None => assert(false),
    }
    ch.close()
}
