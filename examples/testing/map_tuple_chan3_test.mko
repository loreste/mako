// map[K](chan[T], scalar, scalar) and channel in other 3-tuple slots

struct Point {
    x: int
    y: int
}

fn TestMapTupleChanIntInt() {
    let mut m = make(map[string](chan[int], int, int))
    let ch = chan_open[int](1)
    let _ = ch.send(42)
    m["w"] = (ch, 7, 8)
    let t = m["w"]
    let c, a, b = t
    assert_eq(a, 7)
    assert_eq(b, 8)
    assert_eq(c.recv(), 42)
    c.close()
}

fn TestMapTupleIntChanInt() {
    let mut m = make(map[int](int, chan[string], int))
    let ch = chan_open[string](1)
    let _ = ch.send("mid")
    m[1] = (1, ch, 2)
    let t = m[1]
    let x, c, y = t
    assert_eq(x, 1)
    assert_eq(y, 2)
    assert_eq_str(c.recv(), "mid")
    c.close()
}

fn TestMapTupleIntIntChan() {
    let mut m = make(map[bool](int, int, chan[int]))
    let ch = chan_open[int](1)
    let _ = ch.send(99)
    m[true] = (3, 4, ch)
    let t = m[true]
    let a, b, c = t
    assert_eq(a, 3)
    assert_eq(b, 4)
    assert_eq(c.recv(), 99)
    c.close()
}

fn TestMapTupleChanFloatTriple() {
    let mut m = make(map[string](chan[float], float, int))
    let ch = chan_open[float](1)
    let _ = ch.send(1.5)
    m["f"] = (ch, 2.5, 1)
    let t = m["f"]
    let c, f, n = t
    let v = c.recv()
    assert(v > 1.4 && v < 1.6)
    assert(f > 2.4 && f < 2.6)
    assert_eq(n, 1)
    c.close()
}

fn TestMapTupleChanCommaOk() {
    let mut m = make(map[string](chan[int], int, int))
    let ch = chan_open[int](1)
    let _ = ch.send(5)
    m["x"] = (ch, 1, 2)
    let t, ok = m["x"]
    assert(ok)
    let c, a, b = t
    assert_eq(a + b, 3)
    assert_eq(c.recv(), 5)
    let _, miss = m["nope"]
    assert(not miss)
    c.close()
}

fn TestMapTupleChanHelpers() {
    let mut m = make(map[string](chan[int], int, int))
    let a = chan_open[int](1)
    let b = chan_open[int](1)
    let _ = a.send(1)
    let _ = b.send(2)
    m["a"] = (a, 10, 11)
    m["b"] = (b, 20, 21)
    assert_eq(len(m), 2)
    let ks = maps_keys(m)
    assert_eq(len(ks), 2)
    let vs = maps_values(m)
    assert_eq(len(vs), 2)
    let c = maps_clone(m)
    assert_eq(maps_equal(m, c), 1)
    let t = c["a"]
    let ch, x, y = t
    assert_eq(x, 10)
    assert_eq(y, 11)
    assert_eq(ch.recv(), 1)
    a.close()
    b.close()
}

fn TestMapStructKeyTupleChan3() {
    let mut m = make(map[Point](chan[int], int, int))
    let p = Point { x: 1, y: 2 }
    let ch = chan_open[int](1)
    let _ = ch.send(7)
    m[p] = (ch, 1, 2)
    let t = m[p]
    let c, a, b = t
    assert_eq(a + b, 3)
    assert_eq(c.recv(), 7)
    c.close()
}

fn TestMapTupleChanStringTriple() {
    let mut m = make(map[string](string, chan[int], bool))
    let ch = chan_open[int](1)
    let _ = ch.send(3)
    m["k"] = ("label", ch, true)
    let t = m["k"]
    let s, c, flag = t
    assert_eq_str(s, "label")
    assert(flag)
    assert_eq(c.recv(), 3)
    c.close()
}
