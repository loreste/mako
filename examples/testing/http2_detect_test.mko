fn TestHttp2Detect() {
    assert(http2_detect("PRI * HTTP/2.0\r\n\r\nSM\r\n\r\n"))
    assert(not http2_detect("GET / HTTP/1.1\r\n"))
}

fn TestHttp2Settings() {
    let empty = http2_empty_settings()
    assert_eq(len(empty), 9)
    assert_eq(http2_settings_len(empty), 0)
    let pref = "PRI * HTTP/2.0\r\n\r\nSM\r\n\r\n"
    let both = pref + empty
    assert_eq(http2_settings_len(both), 0)
    assert_eq(http2_settings_len("hello"), -1)
}

fn TestHttp2ConnectionBootstrap() {
    let client = http2_client_preface()
    assert(http2_detect(client))
    assert_eq(http2_frame_type(client), 4)
    assert_eq(http2_settings_len(client), 0)
    let ack = http2_settings_ack()
    assert(http2_is_settings_ack(ack))
    assert(not http2_is_settings_ack(http2_empty_settings()))
    let server = http2_server_preface()
    assert_eq(http2_frame_type(server), 4)
    assert_eq(len(server), 18)
    let second = http2_frame_at(server, 1)
    assert(http2_is_settings_ack(second))
}

fn TestHttp2FrameHeader() {
    // empty SETTINGS: len=0 type=4 stream=0 flags=0
    let data = http2_empty_settings()
    assert_eq(http2_frame_type(data), 4)
    assert_eq(http2_frame_stream(data), 0)
    assert_eq(http2_frame_len(data), 0)
    assert_eq(http2_frame_flags(data), 0)
    assert_eq(hpack_decode_indexed("x"), -1)
    assert(str_eq(hpack_static_name(1), ":authority"))
    assert(str_eq(hpack_static_name(31), "content-type"))
    assert_eq(len(hpack_static_name(999)), 0)
}

fn TestQuicDetect() {
    // long-header: 0xC0 | version=1 | dcid_len=4 | "ABCD" | scid_len=2 | "XY"
    let mut c = make([]byte, 13)
    c[0] = byte(192)
    c[1] = byte(0)
    c[2] = byte(0)
    c[3] = byte(0)
    c[4] = byte(1)
    c[5] = byte(4)
    c[6] = byte(65)
    c[7] = byte(66)
    c[8] = byte(67)
    c[9] = byte(68)
    c[10] = byte(2)
    c[11] = byte(88)
    c[12] = byte(89)
    assert(quic_detect(string(c)))
    assert(quic_long_header(string(c)))
    assert(not quic_short_header(string(c)))
    assert_eq(quic_long_type(string(c)), 0) // 0xC0 → Initial
    assert(not quic_is_retry(string(c)))
    assert(not quic_is_version_negotiation(string(c)))
    assert_eq(quic_version(string(c)), 1)
    assert_eq(quic_dcid_len(string(c)), 4)
    assert(str_eq(quic_dcid(string(c)), "ABCD"))
    assert_eq(quic_scid_len(string(c)), 2)
    assert(str_eq(quic_scid(string(c)), "XY"))
    assert_eq(quic_payload_offset(string(c)), 13)
    assert_eq(quic_spin_bit(string(c)), -1)
    assert_eq(quic_key_phase(string(c)), -1)
    assert(not quic_detect("GET /"))
    assert_eq(quic_version("GET /"), -1)
    assert_eq(quic_dcid_len("GET /"), -1)

    // short-header: form=0 fixed=1 spin=1 key_phase=1 → 0x40|0x20|0x04 = 0x64
    let mut sh = make([]byte, 1)
    sh[0] = byte(100)
    assert(quic_short_header(string(sh)))
    assert(not quic_long_header(string(sh)))
    assert(not quic_detect(string(sh))) // detect stays long-only (ASCII-safe)
    assert_eq(quic_spin_bit(string(sh)), 1)
    assert_eq(quic_key_phase(string(sh)), 1)
    assert_eq(quic_version(string(sh)), -1)

    // Retry: long type nibble 3 → 0xC0 | (3<<4) = 0xF0
    let mut ry = make([]byte, 5)
    ry[0] = byte(240)
    ry[1] = byte(0)
    ry[2] = byte(0)
    ry[3] = byte(0)
    ry[4] = byte(1)
    assert(quic_is_retry(string(ry)))
    assert_eq(quic_long_type(string(ry)), 3)
    assert(not quic_is_version_negotiation(string(ry)))

    // Version Negotiation: long + ver=0 + empty CIDs + versions 1 and 2
    // layout: C0 | 00000000 | dlen=0 | slen=0 | 00000001 | 00000002
    let mut vn = make([]byte, 15)
    vn[0] = byte(192)
    vn[1] = byte(0)
    vn[2] = byte(0)
    vn[3] = byte(0)
    vn[4] = byte(0)
    vn[5] = byte(0)
    vn[6] = byte(0)
    vn[7] = byte(0)
    vn[8] = byte(0)
    vn[9] = byte(0)
    vn[10] = byte(1)
    vn[11] = byte(0)
    vn[12] = byte(0)
    vn[13] = byte(0)
    vn[14] = byte(2)
    assert(quic_is_version_negotiation(string(vn)))
    assert(not quic_is_retry(string(vn)))
    assert_eq(quic_vn_version_count(string(vn)), 2)
    assert_eq(quic_vn_version_at(string(vn), 0), 1)
    assert_eq(quic_vn_version_at(string(vn), 1), 2)
    assert_eq(quic_vn_version_at(string(vn), 2), -1)
    assert_eq(quic_vn_select(string(vn), 2), 2)
    assert_eq(quic_vn_select(string(vn), 9), 1) // prefer miss → first

    // CRYPTO frame type 0x06 planted after long-header CIDs (payload region)
    // Unprotected layout: type | offset_varint | length_varint | data
    // Limit: real Initial encrypts this; only works for test bytes.
    let mut cr = make([]byte, 16)
    cr[0] = byte(192)
    cr[1] = byte(0)
    cr[2] = byte(0)
    cr[3] = byte(0)
    cr[4] = byte(1)
    cr[5] = byte(0)
    cr[6] = byte(0)
    cr[7] = byte(0) // reserved packet-number byte
    cr[8] = byte(0)
    cr[9] = byte(0)
    cr[10] = byte(0)
    cr[11] = byte(6) // CRYPTO
    cr[12] = byte(0) // offset varint = 0
    cr[13] = byte(2) // length varint = 2
    cr[14] = byte(65) // 'A'
    cr[15] = byte(66) // 'B'
    assert(quic_has_crypto(string(cr)))
    assert_eq(quic_crypto_offset(string(cr)), 11)
    assert_eq(quic_crypto_data_offset(string(cr)), 14)
    assert_eq(quic_crypto_data_len(string(cr)), 2)
    assert(str_eq(quic_crypto_data(string(cr)), "AB"))
    assert(not quic_has_crypto(string(c)))
}


fn TestTlsRecord() {
    // type=23 (application_data), version=0x0303 (TLS 1.2 legacy), len=2
    let mut r = make([]byte, 5)
    r[0] = byte(23)
    r[1] = byte(3)
    r[2] = byte(3)
    r[3] = byte(0)
    r[4] = byte(2)
    assert_eq(tls_record_type(string(r)), 23)
    assert_eq(tls_record_version(string(r)), 771)
    assert_eq(tls_record_len(string(r)), 2)
    assert_eq(tls_record_type("hi"), -1)
}
