// Nested channel bags:
//   map[K][]Option[chan[T]] / map[K][]Result[chan[T],E]
//   map[K]Option[[]chan[T]] / map[K]Result[[]chan[T],E]

struct Point {
    x: int
    y: int
}

fn TestMapSliceOptionChanInt() {
    let mut m = make(map[string][]Option[chan[int]])
    let a = chan_open[int](1)
    let b = chan_open[int](1)
    let _ = a.send(1)
    let _ = b.send(2)
    m["w"] = [Some(a), None, Some(b)]
    assert_eq(len(m["w"]), 3)
    match m["w"][0] {
        Some(c) => assert_eq(c.recv(), 1),
        None => assert(false),
    }
    match m["w"][1] {
        Some(_) => assert(false),
        None => assert(true),
    }
    match m["w"][2] {
        Some(c) => assert_eq(c.recv(), 2),
        None => assert(false),
    }
    assert_eq(len(m["missing"]), 0)
    a.close()
    b.close()
}

fn TestMapSliceResultChanString() {
    let mut m = make(map[int][]Result[chan[string], string])
    let ch = chan_open[string](1)
    let _ = ch.send("ok")
    m[1] = [Ok(ch), Err("no")]
    match m[1][0] {
        Ok(c) => assert_eq_str(c.recv(), "ok"),
        Err(_) => assert(false),
    }
    match m[1][1] {
        Ok(_) => assert(false),
        Err(e) => assert_eq_str(e, "no"),
    }
    ch.close()
}

fn TestMapOptionSliceChanInt() {
    let mut m = make(map[string]Option[[]chan[int]])
    let a = chan_open[int](1)
    let b = chan_open[int](1)
    let _ = a.send(10)
    let _ = b.send(20)
    m["a"] = Some([a, b])
    m["b"] = None
    match m["a"] {
        Some(row) => {
            assert_eq(len(row), 2)
            assert_eq(row[0].recv(), 10)
            assert_eq(row[1].recv(), 20)
        },
        None => assert(false),
    }
    match m["b"] {
        Some(_) => assert(false),
        None => assert(true),
    }
    match m["missing"] {
        Some(_) => assert(false),
        None => assert(true),
    }
    a.close()
    b.close()
}

fn TestMapResultSliceChanInt() {
    let mut m = make(map[string]Result[[]chan[int], string])
    let ch = chan_open[int](1)
    let _ = ch.send(7)
    m["ok"] = Ok([ch])
    m["err"] = Err("fail")
    match m["ok"] {
        Ok(row) => {
            assert_eq(len(row), 1)
            assert_eq(row[0].recv(), 7)
        },
        Err(_) => assert(false),
    }
    match m["err"] {
        Ok(_) => assert(false),
        Err(s) => assert_eq_str(s, "fail"),
    }
    ch.close()
}

fn TestMapOptionSliceChanStruct() {
    let mut m = make(map[string]Option[[]chan[Point]])
    let ch = chan_open[Point](1)
    let _ = ch.send(Point { x: 3, y: 4 })
    m["p"] = Some([ch])
    match m["p"] {
        Some(row) => {
            let q = row[0].recv()
            assert_eq(q.x, 3)
            assert_eq(q.y, 4)
            row[0].close()
        },
        None => assert(false),
    }
}

fn TestMapSliceOptionChanFloat() {
    let mut m = make(map[bool][]Option[chan[float]])
    let ch = chan_open[float](1)
    let _ = ch.send(2.5)
    m[true] = [Some(ch)]
    match m[true][0] {
        Some(c) => {
            let v = c.recv()
            assert(v > 2.4 && v < 2.6)
            c.close()
        },
        None => assert(false),
    }
}

fn TestMapStructKeyOptionSliceChan() {
    let mut m = make(map[Point]Option[[]chan[int]])
    let p = Point { x: 1, y: 0 }
    let ch = chan_open[int](1)
    let _ = ch.send(99)
    m[p] = Some([ch])
    match m[p] {
        Some(row) => assert_eq(row[0].recv(), 99),
        None => assert(false),
    }
    ch.close()
}

fn TestMapSliceOptionChanHelpers() {
    let mut m = make(map[string][]Option[chan[int]])
    let a = chan_open[int](1)
    let b = chan_open[int](1)
    let _ = a.send(1)
    // Include a Some so []Option[chan] lit monomorph is opt_chan_int (not bare opt_int).
    m["a"] = [Some(a), None]
    m["b"] = [Some(b)]
    let ks = maps_keys(m)
    assert_eq(len(ks), 2)
    let vs = maps_values(m)
    assert_eq(len(vs), 2)
    let c = maps_clone(m)
    assert_eq(maps_equal(m, c), 1)
    match c["a"][0] {
        Some(ch) => assert_eq(ch.recv(), 1),
        None => assert(false),
    }
    match c["a"][1] {
        Some(_) => assert(false),
        None => assert(true),
    }
    a.close()
    b.close()
}

fn TestMapOptionSliceChanCommaOk() {
    let mut m = make(map[string]Option[[]chan[int]])
    let ch = chan_open[int](1)
    let _ = ch.send(5)
    m["x"] = Some([ch])
    let bag, ok = m["x"]
    assert(ok)
    match bag {
        Some(row) => assert_eq(row[0].recv(), 5),
        None => assert(false),
    }
    let _, miss = m["nope"]
    assert(not miss)
    ch.close()
}
