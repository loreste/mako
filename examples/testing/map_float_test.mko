// map[int]float and map[string]float

fn TestMapIntFloat() {
    let mut m = make(map[int]float)
    m[1] = 2.5
    m[2] = 3.0
    assert(m[1] > 2.4)
    assert(m[1] < 2.6)
    assert(has(m, 1))
    assert(not has(m, 99))
    assert_eq(len(m), 2)
    let v, ok = m[2]
    assert(ok)
    assert(v > 2.9)
    delete(m, 1)
    assert(not has(m, 1))
    assert_eq(len(m), 1)
}

fn TestMapStringFloat() {
    let mut m = make(map[string]float)
    m["pi"] = 3.14
    m["e"] = 2.71
    assert(m["pi"] > 3.0)
    assert(has(m, "pi"))
    let v, ok = m["e"]
    assert(ok)
    assert(v > 2.7)
    assert_eq(len(m), 2)
}

fn TestMapFloatHelpers() {
    let mut m = make(map[int]float)
    m[1] = 1.5
    m[2] = 2.5
    let ks = maps_keys(m)
    assert_eq(len(ks), 2)
    let vs = maps_values(m)
    assert_eq(len(vs), 2)
    let c = maps_clone(m)
    assert_eq(maps_equal(m, c), 1)
    maps_clear(c)
    assert_eq(len(c), 0)
    maps_copy(c, m)
    assert_eq(len(c), 2)
}

fn TestMapFloatRange() {
    let mut m = make(map[string]float)
    m["a"] = 1.0
    m["b"] = 2.0
    let mut sum = 0.0
    for _, v in range m {
        sum = sum + v
    }
    assert(sum > 2.9)
    assert(sum < 3.1)
}

fn TestMapFloatKeyInt() {
    let mut m = make(map[float]int)
    m[1.5] = 3
    m[2.0] = 4
    assert_eq(m[1.5], 3)
    assert_eq(m[2.0], 4)
    assert(has(m, 1.5))
    assert(not has(m, 9.0))
    assert_eq(len(m), 2)
    // +0 and -0 are the same key
    m[0.0] = 10
    let neg0 = 0.0 - 0.0
    assert_eq(m[neg0], 10)
    assert_eq(len(m), 3)
    delete(m, 1.5)
    assert(not has(m, 1.5))
}

fn TestMapFloatKeyString() {
    let mut m = make(map[float]string)
    m[1.0] = "one"
    assert_eq_str(m[1.0], "one")
    assert(has(m, 1.0))
    let s, ok = m[1.0]
    assert(ok)
    assert_eq_str(s, "one")
}

fn TestMapFloatKeyFloat() {
    let mut m = make(map[float]float)
    m[0.5] = 1.5
    m[1.5] = 2.5
    assert(m[0.5] > 1.4)
    assert(m[0.5] < 1.6)
    let c = maps_clone(m)
    assert_eq(maps_equal(m, c), 1)
    let ks = maps_keys(m)
    assert_eq(len(ks), 2)
}

fn TestMapFloatKeyRange() {
    let mut m = make(map[float]int)
    m[1.0] = 1
    m[2.0] = 2
    let mut sum = 0
    for _, v in range m {
        sum = sum + v
    }
    assert_eq(sum, 3)
}
