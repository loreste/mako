// f-string format specs: {n:02}, {n:x}, {f:.2f}, string width.

fn TestFStringZeroPad() {
    let n = 7
    assert_eq_str(f"{n:02}", "07")
    assert_eq_str(f"{n:04}", "0007")
    let m = 42
    assert_eq_str(f"id={m:04d}", "id=0042")
}

fn TestFStringHex() {
    let n = 255
    assert_eq_str(f"{n:x}", "ff")
    assert_eq_str(f"{n:X}", "FF")
    assert_eq_str(f"{n:02x}", "ff")
    let k = 10
    assert_eq_str(f"{k:02x}", "0a")
}

fn TestFStringOctBin() {
    let n = 8
    assert_eq_str(f"{n:o}", "10")
    assert_eq_str(f"{n:b}", "1000")
}

fn TestFStringFloatPrec() {
    let x = 3.14159
    assert_eq_str(f"{x:.2f}", "3.14")
    assert_eq_str(f"{x:.0f}", "3")
    assert_eq_str(f"{x:.4}", "3.1416")
}

fn TestFStringWidth() {
    let n = 9
    assert_eq_str(f"{n:3}", "  9")
    let s = "hi"
    assert_eq_str(f"{s:4}", "  hi")
    assert_eq_str(f"{s:<4}", "hi  ")
}

fn TestFStringMixedSpec() {
    let port = 80
    let name = "api"
    assert_eq_str(f"{name}:{port:04}", "api:0080")
}

fn TestFStringStillPlain() {
    let n = 42
    assert_eq_str(f"n={n}", "n=42")
    assert_eq_str(f"brace {{ok}}", "brace {ok}")
}

// ---- printf-ish flag parity seed ----

fn TestFStringSignFlags() {
    let n = 7
    let m = -3
    assert_eq_str(f"{n:+}", "+7")
    assert_eq_str(f"{m:+}", "-3")
    assert_eq_str(f"{n: }", " 7")
    assert_eq_str(f"{m: }", "-3")
}

fn TestFStringAltHexOct() {
    let n = 255
    assert_eq_str(f"{n:#x}", "0xff")
    assert_eq_str(f"{n:#X}", "0XFF")
    let o = 8
    assert_eq_str(f"{o:#o}", "010")
    assert_eq_str(f"{o:#b}", "0b1000")
}

fn TestFStringLeftAlignInt() {
    let n = 9
    assert_eq_str(f"{n:-4}", "9   ")
    assert_eq_str(f"{n:-4d}", "9   ")
    assert_eq_str(f"{n:04}", "0009")
}

fn TestFStringFloatFlags() {
    let x = 3.1
    assert_eq_str(f"{x:+.1f}", "+3.1")
    assert_eq_str(f"{x:8.2f}", "    3.10")
    let y = 1000.0
    assert_eq_str(f"{y:.0e}", "1e+03")
}

fn TestFStringStringDash() {
    let s = "hi"
    assert_eq_str(f"{s:-5}", "hi   ")
    assert_eq_str(f"{s:>5}", "   hi")
}
