// map[int]Struct and map[string]Struct (incl. pack-qualified types).
pull "../pack_types_lib.mko"

struct Point {
    x: int
    y: int
}

fn TestMapIntStruct() {
    let mut m = make(map[int]Point)
    m[1] = Point { x: 10, y: 20 }
    m[2] = Point { x: 1, y: 2 }
    assert_eq(m[1].x, 10)
    assert_eq(m[1].y, 20)
    assert_eq(len(m), 2)
    assert(has(m, 1))
    assert(not has(m, 99))
    delete(m, 1)
    assert(not has(m, 1))
    assert_eq(len(m), 1)
    // missing key → zero value
    assert_eq(m[1].x, 0)
}

fn TestMapStringStruct() {
    let mut m = make(map[string]Point)
    m["a"] = Point { x: 3, y: 4 }
    assert_eq(m["a"].x + m["a"].y, 7)
    let p, ok = m["a"]
    assert(ok)
    assert_eq(p.x, 3)
    let _, miss = m["nope"]
    assert(not miss)
}

fn TestMapStructRange() {
    let mut m = make(map[int]Point)
    m[1] = Point { x: 1, y: 1 }
    m[2] = Point { x: 2, y: 2 }
    let mut sum = 0
    for _, p in range m {
        sum = sum + p.x + p.y
    }
    assert_eq(sum, 6)
}

fn TestMapPackStruct() {
    let mut m = make(map[int]eng.Table)
    m[7] = eng.Table { n: 42 }
    assert_eq(m[7].n, 42)
    assert(has(m, 7))
    let t, ok = m[7]
    assert(ok)
    assert_eq(t.n, 42)
}

fn TestMapsHelpersStruct() {
    let mut m = make(map[int]Point)
    m[1] = Point { x: 1, y: 2 }
    m[2] = Point { x: 3, y: 4 }
    let ks = maps_keys(m)
    assert_eq(len(ks), 2)
    let vs = maps_values(m)
    assert_eq(len(vs), 2)
    let mut sum = 0
    for _, p in range vs {
        sum = sum + p.x + p.y
    }
    assert_eq(sum, 10)
    let c = maps_clone(m)
    assert_eq(c[1].x, 1)
    assert_eq(maps_equal(m, c), 1)
    maps_clear(c)
    assert_eq(len(c), 0)
    maps_copy(c, m)
    assert_eq(len(c), 2)
}

fn TestMapsHelpersII() {
    let mut m = make(map[int]int)
    m[1] = 10
    m[2] = 20
    let ks = maps_keys(m)
    assert_eq(len(ks), 2)
    let vs = maps_values(m)
    assert_eq(len(vs), 2)
    let c = maps_clone(m)
    assert_eq(c[1], 10)
    assert_eq(maps_equal(m, c), 1)
}

fn TestMapsHelpersSS() {
    let mut m = make(map[string]string)
    m["a"] = "x"
    m["b"] = "y"
    let ks = maps_keys(m)
    assert_eq(len(ks), 2)
    let vs = maps_values(m)
    assert_eq(len(vs), 2)
    let c = maps_clone(m)
    assert_eq_str(c["a"], "x")
    assert_eq(maps_equal(m, c), 1)
}

struct Person {
    name: string
    age: int
}

fn TestMapsEqualStructStrings() {
    // Distinct string allocations with same content must still compare equal.
    let mut a = make(map[int]Person)
    let mut b = make(map[int]Person)
    a[1] = Person { name: "Ada", age: 36 }
    b[1] = Person { name: "Ada", age: 36 }
    assert_eq(maps_equal(a, b), 1)
    b[1] = Person { name: "Bob", age: 36 }
    assert_eq(maps_equal(a, b), 0)
}

fn TestMapFloatKeyStruct() {
    let mut m = make(map[float]Point)
    m[1.5] = Point { x: 10, y: 20 }
    m[2.0] = Point { x: 1, y: 2 }
    assert_eq(m[1.5].x, 10)
    assert_eq(m[1.5].y, 20)
    assert(has(m, 1.5))
    assert(not has(m, 9.0))
    assert_eq(len(m), 2)
    // +0 / -0 same key
    m[0.0] = Point { x: 0, y: 1 }
    let neg0 = 0.0 - 0.0
    assert_eq(m[neg0].y, 1)
    let p, ok = m[2.0]
    assert(ok)
    assert_eq(p.x, 1)
    let ks = maps_keys(m)
    assert(len(ks) >= 3)
    let vs = maps_values(m)
    assert(len(vs) >= 3)
    let c = maps_clone(m)
    assert_eq(maps_equal(m, c), 1)
    delete(m, 1.5)
    assert(not has(m, 1.5))
}

fn TestMapFloatKeyPackStruct() {
    let mut m = make(map[float]eng.Table)
    m[3.14] = eng.Table { n: 7 }
    assert_eq(m[3.14].n, 7)
    assert(has(m, 3.14))
}
