// Domain-track seeds (no SIPREC/WebRTC): btree, lsm, mvcc, rollback, gfx, AI.

fn TestBTreeOrdered() {
    let t = btree_new()
    assert_eq(btree_put(t, 30, 3), 0)
    assert_eq(btree_put(t, 10, 1), 0)
    assert_eq(btree_put(t, 20, 2), 0)
    assert_eq(btree_get(t, 10), 1)
    assert_eq(btree_get(t, 20), 2)
    assert_eq(btree_get(t, 30), 3)
    assert_eq(btree_get(t, 99), -1)
    assert_eq(btree_free(t), 0)
}

fn TestLsmFlushGet() {
    let path = "/tmp/mako_lsm_run.log"
    assert_eq(write_file(path, ""), 0)
    let w = wal_open(path)
    let l = lsm_new(32)
    assert_eq(lsm_attach_run(l, w), 0)
    assert_eq(lsm_put(l, 5, 50), 0)
    assert_eq(lsm_get(l, 5), 50)
    assert_eq(lsm_flush(l), 0)
    assert_eq(lsm_flushes(l), 1)
    // After flush mem empty; value still readable from run
    assert_eq(lsm_get(l, 5), 50)
    assert_eq(lsm_free(l), 0)
    assert_eq(wal_close(w), 0)
}

fn TestLsmCompact() {
    let run = "/tmp/mako_lsm_compact_run.log"
    let sst = "/tmp/mako_lsm_compact.sst"
    assert_eq(write_file(run, ""), 0)
    let w = wal_open(run)
    let l = lsm_new(32)
    assert_eq(lsm_attach_run(l, w), 0)
    assert_eq(lsm_put(l, 1, 10), 0)
    assert_eq(lsm_put(l, 2, 20), 0)
    assert_eq(lsm_flush(l), 0)
    // Overlay then flush again — later wins after compact
    assert_eq(lsm_put(l, 1, 11), 0)
    assert_eq(lsm_flush(l), 0)
    let n = lsm_compact(l, sst)
    assert(n >= 2)
    assert_eq(lsm_compactions(l), 1)
    assert_eq(lsm_sst_levels(l), 1)
    assert(lsm_level_len(l, 1) >= 2)
    // Readable from L1 SST after compact
    assert_eq(lsm_get(l, 1), 11)
    assert_eq(lsm_get(l, 2), 20)
    assert_eq(lsm_free(l), 0)
    assert_eq(wal_close(w), 0)
}

fn TestLsmMultiLevel() {
    let run = "/tmp/mako_lsm_multi_run.log"
    let l1 = "/tmp/mako_lsm_multi_l1.sst"
    let l2 = "/tmp/mako_lsm_multi_l2.sst"
    let l3 = "/tmp/mako_lsm_multi_l3.sst"
    assert_eq(write_file(run, ""), 0)
    let w = wal_open(run)
    let l = lsm_new(32)
    assert_eq(lsm_attach_run(l, w), 0)
    assert_eq(lsm_put(l, 10, 100), 0)
    assert_eq(lsm_flush(l), 0)
    assert(lsm_compact(l, l1) >= 1)
    assert_eq(lsm_sst_levels(l), 1)
    assert_eq(lsm_level_len(l, 1), 1)
    // Promote L1 → L2
    assert(lsm_compact_down(l, l2) >= 1)
    assert_eq(lsm_sst_levels(l), 1)
    assert_eq(lsm_level_len(l, 1), 0)
    assert_eq(lsm_level_len(l, 2), 1)
    assert_eq(lsm_get(l, 10), 100)
    // New L1 data, then merge into L2
    assert_eq(lsm_put(l, 20, 200), 0)
    assert_eq(lsm_put(l, 10, 111), 0) // newer wins after compact_down
    assert_eq(lsm_flush(l), 0)
    assert(lsm_compact(l, l1) >= 1)
    assert_eq(lsm_sst_levels(l), 2)
    assert(lsm_compact_down(l, l2) >= 2)
    assert_eq(lsm_get(l, 10), 111)
    assert_eq(lsm_get(l, 20), 200)
    assert_eq(lsm_level_len(l, 1), 0)
    assert(lsm_level_len(l, 2) >= 2)
    // Promote L2 → L3
    assert(lsm_compact_down(l, l3) >= 2)
    assert_eq(lsm_level_len(l, 2), 0)
    assert(lsm_level_len(l, 3) >= 2)
    assert_eq(lsm_get(l, 10), 111)
    assert_eq(lsm_get(l, 20), 200)
    assert(lsm_compactions(l) >= 4)
    assert_eq(lsm_free(l), 0)
    assert_eq(wal_close(w), 0)
}

fn TestPageBTree() {
    let t = pbtree_new()
    assert_eq(pbtree_pages(t), 1)
    assert_eq(pbtree_put(t, 30, 3), 0)
    assert_eq(pbtree_put(t, 10, 1), 0)
    assert_eq(pbtree_put(t, 20, 2), 0)
    assert_eq(pbtree_put(t, 40, 4), 0)
    assert_eq(pbtree_put(t, 50, 5), 0)
    assert_eq(pbtree_put(t, 60, 6), 0)
    assert_eq(pbtree_put(t, 70, 7), 0)
    assert_eq(pbtree_put(t, 80, 8), 0) // forces split → more pages
    assert_eq(pbtree_get(t, 10), 1)
    assert_eq(pbtree_get(t, 30), 3)
    assert_eq(pbtree_get(t, 80), 8)
    assert_eq(pbtree_get(t, 99), -1)
    assert(pbtree_len(t) >= 8)
    assert(pbtree_pages(t) >= 2)
    // update in place
    assert_eq(pbtree_put(t, 10, 100), 0)
    assert_eq(pbtree_get(t, 10), 100)
    assert_eq(pbtree_free(t), 0)
}

fn TestBloomFilter() {
    let b = bloom_new()
    assert_eq(bloom_add(b, 10), 0)
    assert_eq(bloom_add(b, 20), 0)
    assert_eq(bloom_add(b, 30), 0)
    assert_eq(bloom_len(b), 3)
    assert_eq(bloom_maybe(b, 10), 1)
    assert_eq(bloom_maybe(b, 20), 1)
    assert_eq(bloom_maybe(b, 30), 1)
    // Definitely absent keys return 0 (no false negatives)
    assert_eq(bloom_maybe(b, 999001), 0)
    assert_eq(bloom_maybe(b, 999002), 0)
    assert_eq(bloom_free(b), 0)
}

fn TestBtreeAndSstRange() {
    let t = btree_new()
    assert_eq(btree_put(t, 1, 10), 0)
    assert_eq(btree_put(t, 5, 50), 0)
    assert_eq(btree_put(t, 3, 30), 0)
    assert_eq(btree_put(t, 7, 70), 0)
    assert_eq(btree_put(t, 9, 90), 0)
    let n = btree_range(t, 3, 7)
    assert_eq(n, 3)
    assert_eq(range_len(), 3)
    assert_eq(range_key_at(0), 3)
    assert_eq(range_val_at(0), 30)
    assert_eq(range_key_at(1), 5)
    assert_eq(range_val_at(1), 50)
    assert_eq(range_key_at(2), 7)
    assert_eq(range_val_at(2), 70)
    assert_eq(range_key_at(3), -1)
    assert_eq(btree_free(t), 0)

    let path = "/tmp/mako_sst_range.sst"
    let s = sst_build4(path, 2, 20, 4, 40, 6, 60, 8, 80)
    assert_eq(sst_range(s, 4, 6), 2)
    assert_eq(range_key_at(0), 4)
    assert_eq(range_val_at(0), 40)
    assert_eq(range_key_at(1), 6)
    assert_eq(range_val_at(1), 60)
    assert_eq(sst_free(s), 0)
}

fn TestDiskPageManager() {
    let path = "/tmp/mako_pman_seed.dat"
    assert_eq(write_file(path, ""), 0)
    let pm = pman_open(path)
    assert_eq(pman_pages(pm), 1) // superblock only
    let p1 = pman_alloc(pm)
    assert(p1 >= 1)
    let p2 = pman_alloc(pm)
    assert(p2 > p1)
    assert_eq(pman_set(pm, p1, 0, 42), 0)
    assert_eq(pman_set(pm, p1, 1, 99), 0)
    assert_eq(pman_set(pm, p2, 0, 7), 0)
    assert_eq(pman_get(pm, p1, 0), 42)
    assert_eq(pman_get(pm, p1, 1), 99)
    assert_eq(pman_get(pm, p2, 0), 7)
    assert_eq(pman_sync(pm), 0)
    assert(pman_pages(pm) >= 3)
    assert(pman_writes(pm) > 0)
    assert(pman_reads(pm) > 0)
    assert_eq(pman_close(pm), 0)
    // reopen persists
    let pm2 = pman_open(path)
    assert_eq(pman_get(pm2, p1, 0), 42)
    assert_eq(pman_get(pm2, p2, 0), 7)
    assert_eq(pman_close(pm2), 0)
}

fn TestStoreRecoverWal() {
    let path = "/tmp/mako_store_recover.log"
    assert_eq(write_file(path, ""), 0)
    let w = wal_open(path)
    let s = store_new(32)
    assert_eq(store_attach_wal(s, w), 0)
    assert_eq(store_begin(s), 0)
    assert_eq(store_put(s, 3, 30), 0)
    assert_eq(store_put(s, 4, 40), 0)
    assert_eq(store_commit(s), 0)
    assert_eq(store_free(s), 0)
    assert_eq(wal_close(w), 0)

    let w2 = wal_open(path)
    let s2 = store_new(32)
    let applied = store_recover_wal(s2, w2)
    assert(applied >= 2)
    assert_eq(store_get(s2, 3), 30)
    assert_eq(store_get(s2, 4), 40)
    assert_eq(store_free(s2), 0)
    assert_eq(wal_close(w2), 0)
}

fn TestHotReloadWatch() {
    let path = "/tmp/mako_hot_reload_seed.txt"
    assert_eq(write_file(path, "v1"), 0)
    assert(file_mtime_ns(path) > 0)
    let id = hot_reload_watch(path)
    assert(id >= 0)
    assert_eq(hot_reload_changed(path), 0)
    // Bump mtime past second-resolution FS clocks
    let _ = sleep_ms(1100)
    assert_eq(write_file(path, "v2"), 0)
    assert_eq(hot_reload_changed(path), 1)
    assert_eq(hot_reload_changed(path), 0)
}

fn TestMvccSnapshotRead() {
    let m = mvcc_new()
    let _ = mvcc_put(m, 7, 1)
    let r1 = mvcc_begin(m)
    let _ = mvcc_put(m, 7, 2)
    assert_eq(mvcc_get(m, r1, 7), 1)
    let r2 = mvcc_begin(m)
    assert_eq(mvcc_get(m, r2, 7), 2)
    assert(mvcc_versions(m) >= 2)
    assert_eq(mvcc_free(m), 0)
}

fn TestRollbackRing() {
    let r = rollback_new(4)
    let s0 = snap_encode4(1, 2, 3, 4)
    let s1 = snap_encode4(10, 20, 30, 40)
    assert_eq(rollback_push(r, 100, s0), 0)
    assert_eq(rollback_push(r, 101, s1), 0)
    assert_eq(rollback_len(r), 2)
    assert_eq(rollback_get(r, 100, 0), 1)
    assert_eq(rollback_restore_slot0(r, 101), 10)
    assert_eq(rollback_free(r), 0)
}

fn TestGfxAudioPhysics() {
    let w = gfx_window_open(800, 600, "mako")
    assert_eq(gfx_window_width(w), 800)
    assert_eq(gfx_window_height(w), 600)
    assert_eq(gfx_window_close(w), 0)
    let sid = gfx_shader_compile("void main(){}")
    assert(sid > 0)
    assert_eq(audio_mix(100, 200), 300)
    assert_eq(audio_mix(30000, 30000), 32767)
    assert_eq(physics_step_x(0, 1000, 1000), 1000)
    assert_eq(physics_step_v(0, 1000, 1000), 1000)
}

fn TestAiRopeKvGemm() {
    let c = ai_rope_cos(0)
    assert_eq(c, 1000) // cos(0)*1000
    let x = ai_rope_apply_x(1000, 0, 0)
    assert_eq(x, 1000)
    let kv = kv_cache_new(16)
    assert_eq(kv_cache_append(kv, 11, 22), 1)
    assert_eq(kv_cache_append(kv, 33, 44), 2)
    assert_eq(kv_cache_get_k(kv, 0), 11)
    assert_eq(kv_cache_get_v(kv, 1), 44)
    assert_eq(kv_cache_len(kv), 2)
    assert_eq(kv_cache_free(kv), 0)
    // Identity-ish 2x2: [[1,0],[0,1]] * [[2,3],[4,5]] = [[2,3],[4,5]]
    let c00 = gemm2x2(1, 0, 0, 1, 2, 3, 4, 5)
    assert_eq(c00, 2)
    assert_eq(gemm_c01(), 3)
    assert_eq(gemm_c10(), 4)
    assert_eq(gemm_c11(), 5)
    // 1.0f as bits = 1065353216
    let h = f32_to_f16_bits(1065353216)
    assert(h > 0)
}

fn TestDebugFrame() {
    assert_eq(debug_set_loc("main.mko", 42), 1)
    assert_eq(debug_line(), 42)
    assert(str_contains(debug_file(), "main.mko"))
    let js = debug_frame_json()
    assert(str_contains(js, "mako.debug_frame.v1"))
    assert(str_contains(js, "42"))
}
