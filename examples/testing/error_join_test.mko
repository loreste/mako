// error_join: combine two Results' error messages.

fn TestErrorJoinBothOk() {
    let a = Ok(1)
    let b = Ok(2)
    let j = error_join(a, b)
    match j {
        Ok(v) => assert_eq(v, 1),
        Err(_) => assert(false),
    }
}

fn TestErrorJoinOneErr() {
    let a = Ok(1)
    let b = Err("b-fail")
    let j = error_join(a, b)
    match j {
        Ok(_) => assert(false),
        Err(e) => assert(str_contains(e, "b-fail") || str_len(e) > 0),
    }
}

fn TestErrorJoinBothErr() {
    let a = Err("left")
    let b = Err("right")
    let j = error_join(a, b)
    match j {
        Ok(_) => assert(false),
        Err(e) => assert(str_len(e) > 3),
    }
}
