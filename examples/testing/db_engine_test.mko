// Go-style: always use package qualifier
pull "../db_engine/lib.mko"

fn TestKvPutGet() {
    lib.kv_reset()
    assert_eq(lib.kv_put("x", "42"), 0)
    let m = lib.kv_load()
    assert_eq_str(lib.kv_get(m, "x"), "42")
}

fn TestKvLastWriteWins() {
    lib.kv_reset()
    let _ = lib.kv_put("k", "one")
    let _ = lib.kv_put("k", "two")
    let m = lib.kv_load()
    assert_eq_str(lib.kv_get(m, "k"), "two")
}

fn TestKvDelete() {
    lib.kv_reset()
    let _ = lib.kv_put("a", "1")
    let _ = lib.kv_put("b", "2")
    let _ = lib.kv_del("a")
    let m = lib.kv_load()
    assert_eq_str(lib.kv_get(m, "a"), "")
    assert_eq_str(lib.kv_get(m, "b"), "2")
}
