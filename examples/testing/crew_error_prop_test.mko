// Structured child-task error propagation via crew first_err / wait.

fn fail_job() -> Result[int, string] {
    return Err("boom")
}

fn ok_job() -> Result[int, string] {
    return Ok(7)
}

fn TestCrewNotesResultErr() {
    crew t {
        let j = t.kick(fail_job())
        match j.join() {
            Ok(_) => assert(false),
            Err(msg) => assert_eq_str(msg, "boom"),
        }
        assert_eq(t.err_count(), 1)
        assert_eq_str(t.first_err(), "boom")
    }
}

fn TestCrewWaitOk() {
    crew t {
        let j = t.kick(ok_job())
        match j.join() {
            Ok(v) => assert_eq(v, 7),
            Err(_) => assert(false),
        }
        match t.wait() {
            Ok(n) => assert_eq(n, 0),
            Err(_) => assert(false),
        }
    }
}

fn TestCrewWaitErr() {
    crew t {
        let a = t.kick(ok_job())
        let b = t.kick(fail_job())
        let _ = a.join()
        let _ = b.join()
        match t.wait() {
            Ok(_) => assert(false),
            Err(msg) => assert_eq_str(msg, "boom"),
        }
        assert(t.err_count() >= 1)
    }
}
