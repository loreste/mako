// HTTP/3 server surface — unit tests (soft-skip when quiche not linked).
// Live round-trip: MAKO_LIVE_QUIC=1 (quiche client → h3_server).

fn TestH3ServerSurface() {
    if h3_server_available() == 0 {
        assert_eq(h3_server_new("a", "b"), -1)
        assert_eq(h3_server_available(), 0)
        return
    }
    let h = h3_server_new("runtime/certs/dev.crt", "runtime/certs/dev.key")
    if h < 0 {
        // Certs missing in some CI layouts — soft skip.
        return
    }
    let bound = h3_server_bind(h, "127.0.0.1", 18490)
    if bound == 0 {
        let _ = h3_server_close(h)
        return
    }
    assert(h3_server_fd(h) >= 0)
    let pr = h3_server_poll(h, 0)
    assert(pr >= 0)
    assert_eq(h3_accept_stream(h), -1)
    // Accessors on unknown stream return safe defaults / empty.
    assert_eq_str(h3_stream_method(h, 999), "GET")
    assert_eq_str(h3_stream_path(h, 999), "/")
    assert_eq_str(h3_stream_body(h, 999), "")
    assert_eq(h3_server_close(h), 1)
}

fn TestH3ServerIdlePoll() {
    if h3_server_available() == 0 {
        return
    }
    let h = h3_server_new("runtime/certs/dev.crt", "runtime/certs/dev.key")
    if h < 0 {
        return
    }
    if h3_server_bind(h, "127.0.0.1", 18491) == 0 {
        let _ = h3_server_close(h)
        return
    }
    // Idle poll/drive must stay stable (timeouts, no crash).
    var i = 0
    for i < 5 {
        let pr = h3_server_poll(h, 10)
        assert(pr >= 0)
        i++
    }
    assert_eq(h3_server_close(h), 1)
}
