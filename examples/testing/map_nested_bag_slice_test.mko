// Nested bag slices as map values:
//   []Option[Option[T]] / []Option[Result[T,E]] / []Result[Option[T],E] / []Result[Result[T,E],E]
//   Option[[]Option[T]] / Result[[]Option[T],E] / Option[[]Result[T,E]] / Result[[]Result[T,E],E]
//   + channel element variants

struct Point {
    x: int
    y: int
}

fn TestMapSliceOptionOptionInt() {
    let mut m = make(map[string][]Option[Option[int]])
    m["a"] = [Some(Some(1)), Some(None), None]
    assert_eq(len(m["a"]), 3)
    match m["a"][0] {
        Some(inner) => match inner {
            Some(v) => assert_eq(v, 1),
            None => assert(false),
        },
        None => assert(false),
    }
    match m["a"][1] {
        Some(inner) => match inner {
            Some(_) => assert(false),
            None => assert(true),
        },
        None => assert(false),
    }
    match m["a"][2] {
        Some(_) => assert(false),
        None => assert(true),
    }
    assert_eq(len(m["missing"]), 0)
}

fn TestMapSliceOptionResultInt() {
    let mut m = make(map[string][]Option[Result[int, string]])
    m["a"] = [Some(Ok(2)), Some(Err("e")), None]
    match m["a"][0] {
        Some(r) => match r {
            Ok(v) => assert_eq(v, 2),
            Err(_) => assert(false),
        },
        None => assert(false),
    }
    match m["a"][1] {
        Some(r) => match r {
            Ok(_) => assert(false),
            Err(e) => assert_eq_str(e, "e"),
        },
        None => assert(false),
    }
    match m["a"][2] {
        Some(_) => assert(false),
        None => assert(true),
    }
}

fn TestMapSliceResultOptionInt() {
    let mut m = make(map[int][]Result[Option[int], string])
    m[1] = [Ok(Some(3)), Ok(None), Err("x")]
    match m[1][0] {
        Ok(inner) => match inner {
            Some(v) => assert_eq(v, 3),
            None => assert(false),
        },
        Err(_) => assert(false),
    }
    match m[1][1] {
        Ok(inner) => match inner {
            Some(_) => assert(false),
            None => assert(true),
        },
        Err(_) => assert(false),
    }
    match m[1][2] {
        Ok(_) => assert(false),
        Err(e) => assert_eq_str(e, "x"),
    }
}

fn TestMapSliceResultResultInt() {
    let mut m = make(map[string][]Result[Result[int, string], string])
    m["a"] = [Ok(Ok(4)), Ok(Err("inner")), Err("outer")]
    match m["a"][0] {
        Ok(inner) => match inner {
            Ok(v) => assert_eq(v, 4),
            Err(_) => assert(false),
        },
        Err(_) => assert(false),
    }
    match m["a"][1] {
        Ok(inner) => match inner {
            Ok(_) => assert(false),
            Err(e) => assert_eq_str(e, "inner"),
        },
        Err(_) => assert(false),
    }
    match m["a"][2] {
        Ok(_) => assert(false),
        Err(e) => assert_eq_str(e, "outer"),
    }
}

fn TestMapSliceOptionOptionChan() {
    let mut m = make(map[string][]Option[Option[chan[int]]])
    let ch = chan_open[int](1)
    let _ = ch.send(9)
    m["a"] = [Some(Some(ch)), Some(None), None]
    match m["a"][0] {
        Some(inner) => match inner {
            Some(c) => assert_eq(c.recv(), 9),
            None => assert(false),
        },
        None => assert(false),
    }
    match m["a"][1] {
        Some(inner) => match inner {
            Some(_) => assert(false),
            None => assert(true),
        },
        None => assert(false),
    }
    ch.close()
}

fn TestMapOptionOfOptionSlice() {
    let mut m = make(map[string]Option[[]Option[int]])
    m["a"] = Some([Some(1), None, Some(3)])
    m["b"] = None
    match m["a"] {
        Some(xs) => {
            assert_eq(len(xs), 3)
            match xs[0] {
                Some(v) => assert_eq(v, 1),
                None => assert(false),
            }
            match xs[1] {
                Some(_) => assert(false),
                None => assert(true),
            }
            match xs[2] {
                Some(v) => assert_eq(v, 3),
                None => assert(false),
            }
        },
        None => assert(false),
    }
    match m["b"] {
        Some(_) => assert(false),
        None => assert(true),
    }
    match m["missing"] {
        Some(_) => assert(false),
        None => assert(true),
    }
}

fn TestMapResultOfOptionSlice() {
    let mut m = make(map[string]Result[[]Option[int], string])
    m["ok"] = Ok([Some(5), None])
    m["err"] = Err("fail")
    match m["ok"] {
        Ok(xs) => {
            match xs[0] {
                Some(v) => assert_eq(v, 5),
                None => assert(false),
            }
            match xs[1] {
                Some(_) => assert(false),
                None => assert(true),
            }
        },
        Err(_) => assert(false),
    }
    match m["err"] {
        Ok(_) => assert(false),
        Err(e) => assert_eq_str(e, "fail"),
    }
}

fn TestMapOptionOfResultSlice() {
    let mut m = make(map[int]Option[[]Result[string, string]])
    m[1] = Some([Ok("yes"), Err("no")])
    m[2] = None
    match m[1] {
        Some(xs) => {
            match xs[0] {
                Ok(s) => assert_eq_str(s, "yes"),
                Err(_) => assert(false),
            }
            match xs[1] {
                Ok(_) => assert(false),
                Err(e) => assert_eq_str(e, "no"),
            }
        },
        None => assert(false),
    }
    match m[2] {
        Some(_) => assert(false),
        None => assert(true),
    }
}

fn TestMapResultOfResultSlice() {
    let mut m = make(map[string]Result[[]Result[int, string], string])
    m["ok"] = Ok([Ok(7), Err("i")])
    m["err"] = Err("outer")
    match m["ok"] {
        Ok(xs) => {
            match xs[0] {
                Ok(v) => assert_eq(v, 7),
                Err(_) => assert(false),
            }
            match xs[1] {
                Ok(_) => assert(false),
                Err(e) => assert_eq_str(e, "i"),
            }
        },
        Err(_) => assert(false),
    }
    match m["err"] {
        Ok(_) => assert(false),
        Err(e) => assert_eq_str(e, "outer"),
    }
}

fn TestMapSliceOptionOptionStruct() {
    let mut m = make(map[string][]Option[Option[Point]])
    m["a"] = [Some(Some(Point { x: 1, y: 2 })), Some(None)]
    match m["a"][0] {
        Some(inner) => match inner {
            Some(p) => {
                assert_eq(p.x, 1)
                assert_eq(p.y, 2)
            },
            None => assert(false),
        },
        None => assert(false),
    }
}

fn TestMapNestedBagSliceHelpers() {
    let mut m = make(map[string][]Option[Option[int]])
    m["a"] = [Some(Some(1))]
    m["b"] = [Some(Some(2)), None]
    let ks = maps_keys(m)
    assert_eq(len(ks), 2)
    let c = maps_clone(m)
    assert_eq(maps_equal(m, c), 1)
    match c["a"][0] {
        Some(inner) => match inner {
            Some(v) => assert_eq(v, 1),
            None => assert(false),
        },
        None => assert(false),
    }
}

fn TestMapOptionOfOptionSliceCommaOk() {
    let mut m = make(map[string]Option[[]Option[int]])
    m["x"] = Some([Some(8), None])
    let bag, ok = m["x"]
    assert(ok)
    match bag {
        Some(xs) => {
            match xs[0] {
                Some(v) => assert_eq(v, 8),
                None => assert(false),
            }
        },
        None => assert(false),
    }
    let _, ok2 = m["z"]
    assert(not ok2)
}
