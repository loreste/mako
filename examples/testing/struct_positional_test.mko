// Go-style positional struct literals: `Point{1, 2}` alongside named form.

struct Point { x: int, y: int }
struct Wrap { p: Point, tag: string }

func sumP(p Point) int { return p.x + p.y }
func ok(p Point) bool { return p.x > 0 }

func TestPositionalBasic() {
    let a = Point{1, 2}
    assert_eq(a.x, 1)
    assert_eq(a.y, 2)
    assert_eq(sumP(Point{7, 8}), 15)
}

func TestPositionalNested() {
    let w = Wrap{Point{5, 6}, "hi"}
    assert_eq(sumP(w.p), 11)
    assert_eq_str(w.tag, "hi")
}

func TestPositionalEmptyIsZeroValue() {
    let z = Point{}
    assert_eq(z.x, 0)
    assert_eq(z.y, 0)
}

func TestNamedStillWorks() {
    let b = Point { x: 3, y: 4 }
    assert_eq(sumP(b), 7)
}

func TestLiteralInConditionCallIsUnambiguous() {
    // `if ok(Point{9, 0}) { … }` — nested literal inside a call in a condition.
    var hit = 0
    if ok(Point{9, 0}) {
        hit = 1
    }
    assert_eq(hit, 1)

    // A bare identifier condition followed by a block stays a block, not a literal.
    let flag = true
    var n = 0
    if flag {
        n = 5
    }
    assert_eq(n, 5)
}
