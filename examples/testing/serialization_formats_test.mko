fn TestYamlTomlSeeds() {
    let y = "name: Ada\ncity: Paris\n"
    assert_eq_str(yaml_get_string(y, "name"), "Ada")
    assert_eq_str(yaml_get_string(y, "city"), "Paris")
    assert_eq_str(yaml_get_string(y, "missing"), "")

    let t = "name = \"Grace\"\nport = 8080\n"
    assert_eq_str(toml_get_string(t, "name"), "Grace")
    assert_eq(toml_get_int(t, "port"), 8080)
}

fn TestBinaryFormatSeeds() {
    // msgpack compact encoding per spec
    assert_eq_str(msgpack_int_hex(42), "2a")        // positive fixint
    assert_eq_str(msgpack_int_hex(128), "cc80")      // uint8
    assert_eq_str(msgpack_int_hex(-33), "d0df")      // int8
    assert_eq_str(msgpack_int_hex(256), "cd0100")    // uint16
    // cbor compact encoding per spec
    assert_eq_str(cbor_int_hex(23), "17")            // tiny (< 24 → inline)
    assert_eq_str(cbor_int_hex(42), "182a")          // 1-byte (24..255)
    assert_eq_str(cbor_int_hex(-1), "20")            // major 1, val 0
    assert_eq_str(cbor_int_hex(256), "190100")       // 2-byte uint16
    // avro zig-zag varint
    assert_eq_str(avro_long_hex(64), "8001")
    assert_eq_str(avro_long_hex(-1), "01")
}
