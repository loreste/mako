// map[K]Option[[]T] / map[K]Result[[]T,E] — optional / fallible slice values
// (bag stores heap-boxed slice headers via mako_some_ptr / mako_ok_ptr).

struct Point {
    x: int
    y: int
}

fn TestMapOptionIntSlice() {
    let mut m = make(map[string]Option[[]int])
    m["a"] = Some([1, 2, 3])
    m["b"] = None
    assert_eq(len(m), 2)
    match m["a"] {
        Some(xs) => {
            assert_eq(len(xs), 3)
            assert_eq(xs[0], 1)
            assert_eq(xs[2], 3)
        },
        None => assert(false),
    }
    match m["b"] {
        Some(_) => assert(false),
        None => assert(true),
    }
    // missing key → None
    match m["missing"] {
        Some(_) => assert(false),
        None => assert(true),
    }
    delete(m, "b")
    assert(not has(m, "b"))
}

fn TestMapOptionStringSlice() {
    let mut m = make(map[int]Option[[]string])
    m[1] = Some(["x", "y"])
    match m[1] {
        Some(xs) => {
            assert_eq_str(xs[0], "x")
            assert_eq_str(xs[1], "y")
        },
        None => assert(false),
    }
}

fn TestMapOptionStructSlice() {
    let mut m = make(map[string]Option[[]Point])
    m["pts"] = Some([Point { x: 1, y: 2 }, Point { x: 3, y: 4 }])
    match m["pts"] {
        Some(xs) => {
            assert_eq(len(xs), 2)
            assert_eq(xs[0].x, 1)
            assert_eq(xs[1].y, 4)
        },
        None => assert(false),
    }
}

fn TestMapResultIntSlice() {
    let mut m = make(map[string]Result[[]int, string])
    m["ok"] = Ok([10, 20])
    m["err"] = Err("fail")
    match m["ok"] {
        Ok(xs) => {
            assert_eq(xs[0], 10)
            assert_eq(xs[1], 20)
        },
        Err(_) => assert(false),
    }
    match m["err"] {
        Ok(_) => assert(false),
        Err(e) => assert_eq_str(e, "fail"),
    }
}

fn TestMapStructKeyOptionSlice() {
    let mut m = make(map[Point]Option[[]int])
    let k = Point { x: 0, y: 1 }
    m[k] = Some([7, 8])
    match m[k] {
        Some(xs) => assert_eq(xs[0], 7),
        None => assert(false),
    }
}

fn TestMapOptionOfSliceHelpers() {
    let mut m = make(map[string]Option[[]int])
    m["a"] = Some([1])
    m["b"] = Some([2, 3])
    let c = maps_clone(m)
    assert_eq(maps_equal(m, c), 1)
    maps_clear(c)
    assert_eq(len(c), 0)
    assert_eq(len(m), 2)
}
