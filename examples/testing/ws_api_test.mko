// WebSocket RFC6455 — handshake helpers, soft API failures, loopback e2e.

fn TestWebSocketHandshakeHelpers() {
    let key = "dGhlIHNhbXBsZSBub25jZQ=="
    let accept = ws_accept_key(key)
    assert_eq_str(accept, "s3pPLMBiTxaQ9kYGzzhZRbK+xOo=")

    let req = ws_client_request("example.com", "/chat", key)
    assert(str_contains(req, "GET /chat HTTP/1.1"))
    assert(str_contains(req, "Host: example.com"))
    assert(str_contains(req, "Upgrade: websocket"))
    assert(str_contains(req, "Sec-WebSocket-Version: 13"))
    assert_eq(ws_upgrade_request_ok(req), 1)

    let resp = "HTTP/1.1 101 Switching Protocols\r\nUpgrade: websocket\r\nConnection: Upgrade\r\nSec-WebSocket-Accept: s3pPLMBiTxaQ9kYGzzhZRbK+xOo=\r\n\r\n"
    assert_eq(ws_client_accept_ok(key, resp), 1)
    assert_eq(ws_client_accept_ok(key, "HTTP/1.1 400 Bad Request\r\n\r\n"), 0)
}

fn TestWebSocketApiSoftFailures() {
    assert_eq(ws_accept(-1), -1)
    assert_eq_str(ws_recv(-1, 128), "")
    assert_eq(ws_send_text(-1, "x"), -1)
    assert_eq(ws_send_binary(-1, "x"), -1)
    assert_eq(ws_send_ping(-1, "x"), -1)
    assert_eq(ws_send_pong(-1, "x"), -1)
    assert_eq(ws_send_close(-1, 1000, ""), -1)
    assert_eq(ws_close(-1), 0)
    assert_eq(ws_client_connect("127.0.0.1", 1, "/", "dGhlIHNhbXBsZSBub25jZQ=="), -1)
    assert_eq(ws_client_send_text(-1, "x"), -1)
    assert_eq(ws_client_send_binary(-1, "x"), -1)
    assert_eq(ws_client_send_ping(-1, "x"), -1)
    assert_eq(ws_client_send_close(-1, 1000, ""), -1)
    assert_eq_str(ws_client_recv(-1, 128), "")
    assert_eq(ws_last_opcode(), 0)
}

// Server task: accept one WS client, echo text then binary, close with 1000.
fn ws_loopback_server(lfd: int) -> int {
    let cfd = ws_accept(lfd)
    if cfd < 0 {
        return 1
    }
    let msg = ws_recv(cfd, 8192)
    if str_len(msg) == 0 {
        let _ = ws_close(cfd)
        return 2
    }
    assert_eq(ws_last_opcode(), 1)
    assert_eq(ws_last_status(), 0)
    assert_eq(ws_send_text(cfd, msg), 0)

    let bin = ws_recv(cfd, 8192)
    assert_eq_str(bin, "bin-payload")
    assert_eq(ws_last_opcode(), 2)
    assert_eq(ws_send_binary(cfd, bin), 0)

    // Client may ping; auto-pong is handled inside recv. Also accept close.
    // Close-frame timing is racy on slow CI — tolerate empty/fin without hard fail.
    let fin = ws_recv(cfd, 256)
    if str_len(fin) == 0 {
        // Prefer close opcode / EOF; close code is best-effort.
        if ws_last_opcode() == 8 && ws_last_close_code() != 0 {
            assert_eq(ws_last_close_code(), 1000)
        }
    }
    let _ = ws_send_close(cfd, 1000, "done")
    let _ = ws_close(cfd)
    return 0
}

fn TestWebSocketLoopback() {
    // Ephemeral-ish port: avoid clashing with concurrent suite jobs / TIME_WAIT.
    let port = 18771 + (now_ms() % 1000)
    let lfd = tcp_listen_addr("127.0.0.1", port)
    if lfd < 0 {
        // port busy — soft skip
        return
    }
    let key = "dGhlIHNhbXBsZSBub25jZQ=="
    crew t {
        let j = t.kick(ws_loopback_server(lfd))
        // Give accept() a beat on slow CI runners (macOS Actions).
        sleep_ms(100)
        let c = ws_client_connect("127.0.0.1", port, "/echo", key)
        if c < 0 {
            // connect race / sandbox — soft skip (server job may still exit non-zero)
            let _ = j.join()
            let _ = tcp_close(lfd)
            return
        }

        // Text echo (short frame)
        assert_eq(ws_client_send_text(c, "hello-ws"), 0)
        let reply = ws_client_recv(c, 4096)
        assert_eq_str(reply, "hello-ws")
        assert_eq(ws_last_opcode(), 1)
        assert_eq(ws_last_fin(), 1)
        assert_eq(ws_last_status(), 0)

        // Binary echo
        assert_eq(ws_client_send_binary(c, "bin-payload"), 0)
        let breply = ws_client_recv(c, 4096)
        assert_eq_str(breply, "bin-payload")
        assert_eq(ws_last_opcode(), 2)

        // Ping (server auto-pongs inside its next recv)
        assert_eq(ws_client_send_ping(c, "ping"), 0)

        // Close handshake (masked client close; server records code 1000)
        assert_eq(ws_client_send_close(c, 1000, "bye"), 0)
        let _ = ws_close(c)
        assert_eq(j.join(), 0)
    }
    let _ = tcp_close(lfd)
}

// Second loopback: medium payload (extended length) and multi-message session.
fn ws_echo_server_n(lfd: int) -> int {
    let cfd = ws_accept(lfd)
    if cfd < 0 {
        return 1
    }
    let mut i = 0
    while i < 3 {
        let msg = ws_recv(cfd, 65536)
        if str_len(msg) == 0 {
            let _ = ws_close(cfd)
            return 2
        }
        if ws_last_opcode() == 2 {
            assert_eq(ws_send_binary(cfd, msg), 0)
        } else {
            assert_eq(ws_send_text(cfd, msg), 0)
        }
        i = i + 1
    }
    let _ = ws_send_close(cfd, 1000, "")
    let _ = ws_close(cfd)
    return 0
}

fn TestWebSocketMediumPayload() {
    let port = 19772 + (now_ms() % 1000)
    let lfd = tcp_listen_addr("127.0.0.1", port)
    if lfd < 0 {
        return
    }
    let key = "dGhlIHNhbXBsZSBub25jZQ=="
    // 200-byte payload forces 16-bit length field
    let chunk = "01234567890123456789012345678901234567890123456789"
    let med = chunk + chunk + chunk + chunk
    assert(str_len(med) == 200)
    crew t {
        let j = t.kick(ws_echo_server_n(lfd))
        sleep_ms(100)
        let c = ws_client_connect("127.0.0.1", port, "/", key)
        if c < 0 {
            let _ = j.join()
            let _ = tcp_close(lfd)
            return
        }
        assert_eq(ws_client_send_text(c, med), 0)
        assert_eq_str(ws_client_recv(c, 65536), med)
        assert_eq(ws_client_send_text(c, "two"), 0)
        assert_eq_str(ws_client_recv(c, 4096), "two")
        assert_eq(ws_client_send_binary(c, "three"), 0)
        assert_eq_str(ws_client_recv(c, 4096), "three")
        let _ = ws_client_send_close(c, 1000, "")
        let _ = ws_close(c)
        assert_eq(j.join(), 0)
    }
    let _ = tcp_close(lfd)
}
