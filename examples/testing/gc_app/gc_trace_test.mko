// Tracing GC app tests ([package] gc = true).

fn TestGcTraceRootsAndEdges() {
    assert_eq(gc_enabled(), 1)
    let a = gc_alloc(32)
    let b = gc_alloc(16)
    assert(a != 0)
    assert(b != 0)
    assert_eq(gc_root(a), 1)
    assert_eq(gc_link(a, b), 1)
    assert_eq(gc_root_count(), 1)
    let orphan = gc_alloc(8)
    assert(orphan != 0)
    let live0 = gc_live()
    assert(live0 >= 3)
    let freed = gc_collect()
    // orphan unmarked + not rooted → freed; a root + b via edge survive
    assert(freed >= 1)
    assert(gc_live() >= 2)
    assert_eq(gc_unroot(a), 1)
    let fre2 = gc_collect()
    assert(fre2 >= 1)
}

fn TestGcMarkWithoutRoot() {
    // Without roots, collect frees everything (marks cleared first).
    let x = gc_alloc(4)
    assert(x != 0)
    // Manual mark alone does not survive collect (marks cleared at start of collect).
    let _ = gc_mark(x)
    let f = gc_collect()
    assert(f >= 1)
}
