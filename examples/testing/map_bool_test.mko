// map[K]bool (set-style) and []bool

struct Point {
    x: int
    y: int
}

fn TestMapStringBool() {
    let mut m = make(map[string]bool)
    m["a"] = true
    m["b"] = false
    assert(m["a"])
    assert(not m["b"])
    assert(has(m, "a"))
    assert(not has(m, "z"))
    assert_eq(len(m), 2)
    let v, ok = m["a"]
    assert(ok)
    assert(v)
    delete(m, "a")
    assert(not has(m, "a"))
    assert_eq(len(m), 1)
    // missing → false
    assert(not m["missing"])
}

fn TestMapIntBool() {
    let mut m = make(map[int]bool)
    m[1] = true
    m[2] = true
    assert(m[1])
    assert(has(m, 1))
    assert(not has(m, 99))
    assert_eq(len(m), 2)
    let mut n = 0
    for _, v in range m {
        if v {
            n = n + 1
        }
    }
    assert_eq(n, 2)
}

fn TestMapFloatBool() {
    let mut m = make(map[float]bool)
    m[1.5] = true
    assert(m[1.5])
    assert(has(m, 1.5))
    let neg0 = 0.0 - 0.0
    m[0.0] = true
    assert(m[neg0])
}

fn TestMapStructBool() {
    let mut m = make(map[Point]bool)
    m[Point { x: 1, y: 2 }] = true
    assert(m[Point { x: 1, y: 2 }])
    assert(has(m, Point { x: 1, y: 2 }))
    assert(not has(m, Point { x: 0, y: 0 }))
}

fn TestMapBoolHelpers() {
    let mut m = make(map[string]bool)
    m["x"] = true
    m["y"] = false
    let ks = maps_keys(m)
    assert_eq(len(ks), 2)
    let vs = maps_values(m)
    assert_eq(len(vs), 2)
    let c = maps_clone(m)
    assert_eq(maps_equal(m, c), 1)
    maps_clear(c)
    assert_eq(len(c), 0)
    maps_copy(c, m)
    assert_eq(len(c), 2)
}

fn TestBoolSlice() {
    let mut s = make([]bool, 0, 4)
    s = append(s, true)
    s = append(s, false)
    s = append(s, true)
    assert_eq(len(s), 3)
    assert(s[0])
    assert(not s[1])
    assert(s[2])
    s[1] = true
    assert(s[1])
    let t = s[0:2]
    assert_eq(len(t), 2)
    assert(t[0])
    assert(t[1])
}

fn TestBoolSliceLit() {
    let s: []bool = [true, false, true]
    assert_eq(len(s), 3)
    assert(s[0])
    assert(not s[1])
    let inferred = [true, true]
    assert_eq(len(inferred), 2)
    assert(inferred[0])
}

fn TestMapBoolKeyInt() {
    let mut m = make(map[bool]int)
    m[true] = 1
    m[false] = 2
    assert_eq(m[true], 1)
    assert_eq(m[false], 2)
    assert(has(m, true))
    assert(has(m, false))
    assert_eq(len(m), 2)
    m[true] = 10
    assert_eq(m[true], 10)
    assert_eq(len(m), 2)
    delete(m, false)
    assert(not has(m, false))
    assert_eq(len(m), 1)
    // missing → 0
    assert_eq(m[false], 0)
}

fn TestMapBoolKeyString() {
    let mut m = make(map[bool]string)
    m[true] = "yes"
    m[false] = "no"
    assert_eq_str(m[true], "yes")
    assert_eq_str(m[false], "no")
    let s, ok = m[true]
    assert(ok)
    assert_eq_str(s, "yes")
}

fn TestMapBoolKeyFloat() {
    let mut m = make(map[bool]float)
    m[true] = 1.5
    assert(m[true] > 1.4)
    assert(m[true] < 1.6)
}

fn TestMapBoolKeyBool() {
    let mut m = make(map[bool]bool)
    m[true] = false
    m[false] = true
    assert(not m[true])
    assert(m[false])
}

fn TestMapBoolKeyStruct() {
    let mut m = make(map[bool]Point)
    m[true] = Point { x: 1, y: 2 }
    m[false] = Point { x: 3, y: 4 }
    assert_eq(m[true].x, 1)
    assert_eq(m[false].y, 4)
    assert(has(m, true))
    let p, ok = m[false]
    assert(ok)
    assert_eq(p.x, 3)
}

fn TestMapBoolKeyHelpers() {
    let mut m = make(map[bool]int)
    m[true] = 7
    m[false] = 8
    let ks = maps_keys(m)
    assert_eq(len(ks), 2)
    let vs = maps_values(m)
    assert_eq(len(vs), 2)
    let mut sum = 0
    for _, v in range vs {
        sum = sum + v
    }
    assert_eq(sum, 15)
    let c = maps_clone(m)
    assert_eq(maps_equal(m, c), 1)
    maps_clear(c)
    assert_eq(len(c), 0)
    maps_copy(c, m)
    assert_eq(len(c), 2)
}

fn TestMapBoolKeyRange() {
    let mut m = make(map[bool]int)
    m[true] = 1
    m[false] = 2
    let mut sum = 0
    for k, v in range m {
        if k {
            sum = sum + v * 10
        } else {
            sum = sum + v
        }
    }
    // true→1 → 10; false→2 → 2
    assert_eq(sum, 12)
}
