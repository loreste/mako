pull "database/sql"

fn TestPoolAcquireRelease() {
    let mut pool = sql.new_pool("postgres://test", 3)
    assert_eq(pool.size(), 0)
    let a = pool.acquire()
    assert_eq(a, 0)
    assert_eq(pool.size(), 1)
    let b = pool.acquire()
    assert_eq(b, 1)
    assert_eq(pool.active(), 2)
    pool.release(a)
    assert_eq(pool.idle(), 1)
    assert_eq(pool.active(), 1)
    let c = pool.acquire()
    assert_eq(c, 0)
    assert_eq(pool.size(), 2)
}

fn TestPoolExhausted() {
    let mut pool = sql.new_pool("postgres://test", 2)
    let _ = pool.acquire()
    let _ = pool.acquire()
    let c = pool.acquire()
    assert_eq(c, -1)
}
