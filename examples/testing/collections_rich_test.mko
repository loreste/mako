// Rich collections: set, heap, ring, stats, concat, range.

fn TestListStats() {
    let a = [3, 1, 4, 1, 5]
    assert_eq(list_sum_int(a), 14)
    assert_eq(list_min_int(a), 1)
    assert_eq(list_max_int(a), 5)
    let b = list_concat_int([1, 2], [3, 4])
    assert_eq(len(b), 4)
    assert_eq(b[3], 4)
    assert_eq(list_eq_int([1, 2], [1, 2]), 1)
    assert_eq(list_eq_int([1, 2], [1, 3]), 0)
    let f = list_fill_int(3, 7)
    assert_eq(len(f), 3)
    assert_eq(f[0], 7)
    let r = list_range_int(2, 6)
    assert_eq(len(r), 4)
    assert_eq(r[0], 2)
    assert_eq(r[3], 5)
}

fn TestSetOps() {
    let a = slices_unique([1, 2, 3, 2])
    let b = slices_unique([2, 3, 4])
    let u = set_union_int(a, b)
    assert_eq(len(u), 4)
    assert_eq(set_has_int(u, 1), 1)
    assert_eq(set_has_int(u, 9), 0)
    let inter = set_intersect_int(a, b)
    assert_eq(len(inter), 2)
    assert_eq(set_has_int(inter, 2), 1)
    let d = set_diff_int(a, b)
    assert_eq(len(d), 1)
    assert_eq(d[0], 1)
    let sorted = sort_ints([1, 3, 5, 7, 9])
    assert_eq(list_binary_search_int(sorted, 5), 2)
    assert_eq(list_binary_search_int(sorted, 6), -1)
}

fn TestHeap() {
    let mut h = list_new_int()
    h = heap_push_int(h, 5)
    h = heap_push_int(h, 1)
    h = heap_push_int(h, 3)
    assert_eq(heap_peek_int(h), 1)
    h = heap_pop_int(h)
    assert_eq(heap_popped_int(), 1)
    assert_eq(heap_peek_int(h), 3)
    h = heap_pop_int(h)
    assert_eq(heap_popped_int(), 3)
    h = heap_pop_int(h)
    assert_eq(heap_popped_int(), 5)
}

fn TestRing() {
    // Product lock-free ring (mako_std.h): ids are 1-based; push returns 1 on success.
    let id = ring_new(3)
    assert(id > 0)
    assert_eq(ring_cap(id), 3)
    assert_eq(ring_push(id, 10), 1)
    assert_eq(ring_push(id, 20), 1)
    assert_eq(ring_push(id, 30), 1)
    assert_eq(ring_len(id), 3)
    // full: push fails
    assert_eq(ring_push(id, 40), 0)
    assert_eq(ring_peek(id), 10)
    assert_eq(ring_pop(id), 10)
    assert_eq(ring_pop(id), 20)
    assert_eq(ring_pop(id), 30)
}

fn TestListStringConcat() {
    let c = list_concat_str(["a", "b"], ["c"])
    assert_eq(len(c), 3)
    assert_eq_str(c[2], "c")
}
