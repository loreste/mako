// HTTP router / request / response tests — v0.2.0

pull "net/http"

fn TestTextResponse() {
    let r = http.text_response(200, "hello")
    assert_eq(r.status, 200)
    assert_eq_str(r.body, "hello")
    assert_eq_str(r.content_type, "text/plain")
}

fn TestJsonResponse() {
    let r = http.json_response(404, "{\"error\":\"not found\"}")
    assert_eq(r.status, 404)
    assert_eq_str(r.content_type, "application/json")
}

fn TestRouterMatch() {
    let mut router = http.new_router()
    router.add("GET", "/api/users", 1)
    router.add("POST", "/api/users", 2)
    router.add("GET", "/health", 3)
    router.add("*", "/", 4)
    assert_eq(router.match_route("GET", "/api/users"), 1)
    assert_eq(router.match_route("POST", "/api/users"), 2)
    assert_eq(router.match_route("GET", "/health"), 3)
    assert_eq(router.match_route("GET", "/"), 4)
    assert_eq(router.match_route("DELETE", "/"), 4)
    assert_eq(router.match_route("GET", "/unknown"), -1)
}

fn TestRouterEmpty() {
    let router = http.new_router()
    assert_eq(router.size(), 0)
    assert_eq(router.match_route("GET", "/"), -1)
}

fn TestRouterPrefixMatch() {
    let mut router = http.new_router()
    router.add("GET", "/api", 1)
    assert_eq(router.match_route("GET", "/api/users"), 1)
    assert_eq(router.match_route("GET", "/api/posts"), 1)
}

fn TestRouterLongestMatch() {
    // Shorter prefix registered first — longer path still wins.
    let mut router = http.new_router()
    router.add("GET", "/api", 1)
    router.add("GET", "/api/v1", 2)
    assert_eq(router.match_route("GET", "/api/v1/users"), 2)
    assert_eq(router.match_route("GET", "/api/other"), 1)
    assert_eq(router.match_route("GET", "/api/v1"), 2)
}
