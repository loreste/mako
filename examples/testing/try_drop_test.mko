// SAFE-006: `?` early-return frees owning locals (slices, maps, strings).

fn fail() -> Result[int, string] {
    return Err("boom")
}

fn ok_one() -> Result[int, string] {
    return Ok(1)
}

fn work_err() -> Result[int, string] {
    let mut m = make(map[string]int)
    m["a"] = 1
    let mut s = make([]int, 32)
    s[0] = 7
    let owned = f"x{1}"
    let v = fail()?
    return Ok(v + m["a"] + s[0] + len(owned))
}

fn work_ok() -> Result[int, string] {
    let mut s = make([]int, 8)
    s[0] = 7
    let v = ok_one()?
    return Ok(v + s[0])
}

fn TestTryEarlyFreesOwns() {
    match work_err() {
        Ok(_) => assert(false),
        Err(e) => assert(e == "boom"),
    }
}

fn TestTrySuccessStillFrees() {
    match work_ok() {
        Ok(n) => assert(n == 8),
        Err(_) => assert(false),
    }
}
