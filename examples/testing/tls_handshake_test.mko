fn TestTlsHandshakeHello() {
    // 32-byte client/server random (ASCII seed — not crypto RNG).
    let cr = "0123456789abcdef0123456789abcdef"
    let sr = "fedcba9876543210fedcba9876543210"
    assert_eq(len(cr), 32)
    assert_eq(len(sr), 32)
    let ch = tls_client_hello(cr)
    assert_eq(tls_client_hello_legacy_version(ch), 771)
    assert(str_eq(tls_client_hello_random(ch), cr))
    assert_eq(tls_client_hello_has_aes128_gcm(ch), 1)
    assert_eq(len(tls_client_hello("short")), 0)
    let sh = tls_server_hello(sr)
    assert(str_eq(tls_server_hello_random(sh), sr))
    assert_eq(len(tls_server_hello_random(ch)), 0)
}

fn ch_sh_seed() -> string {
    let cr = "0123456789abcdef0123456789abcdef"
    let sr = "fedcba9876543210fedcba9876543210"
    return tls_client_hello(cr) + tls_server_hello(sr)
}

fn TestTlsCertificateFinished() {
    let der = "DER-CERT-BYTES-SEED"
    let cert = tls_certificate(der)
    assert(str_eq(tls_certificate_der(cert), der))
    // ecdsa_secp256r1_sha256 = 0x0403 = 1027
    let cv = tls_certificate_verify(1027, "sig-bytes")
    assert_eq(tls_certificate_verify_scheme(cv), 1027)
    assert(str_eq(tls_certificate_verify_sig(cv), "sig-bytes"))
    let key = "0123456789abcdef0123456789abcdef"
    let transcript = ch_sh_seed()
    let a = tls_finished_verify_data_hex(key, transcript)
    let b = tls_finished_verify_data_hex(key, transcript)
    assert_eq(len(a), 64)
    assert(str_eq(a, b))
    assert(not str_eq(a, tls_finished_verify_data_hex(key, "other")))
}

fn TestTlsTranscriptFinished() {
    // Accumulator: append CH||SH then Finished matches one-shot verify_data.
    let key = "0123456789abcdef0123456789abcdef"
    let cr = "0123456789abcdef0123456789abcdef"
    let sr = "fedcba9876543210fedcba9876543210"
    let ch = tls_client_hello(cr)
    let sh = tls_server_hello(sr)
    let _ = tls_transcript_reset()
    assert_eq(tls_transcript_len(), 0)
    let _ = tls_transcript_append(ch)
    let _ = tls_transcript_append(sh)
    assert_eq(tls_transcript_len(), len(ch) + len(sh))
    let via_tx = tls_transcript_finished_hex(key)
    let direct = tls_finished_verify_data_hex(key, ch + sh)
    assert_eq(len(via_tx), 64)
    assert(str_eq(via_tx, direct))
    let _ = tls_transcript_reset()
    assert_eq(tls_transcript_len(), 0)
}

fn TestTlsTrafficSecrets() {
    // Derive-Secret demo: handshake secret → c/s hs traffic (distinct, deterministic).
    let hs = "0123456789abcdef0123456789abcdef"
    let tx = ch_sh_seed()
    let c = tls_client_handshake_traffic_secret_hex(hs, tx)
    let s = tls_server_handshake_traffic_secret_hex(hs, tx)
    assert_eq(len(c), 64)
    assert_eq(len(s), 64)
    assert(not str_eq(c, s))
    assert(str_eq(c, tls_client_handshake_traffic_secret_hex(hs, tx)))
    assert(str_eq(c, tls_derive_secret_hex(hs, "c hs traffic", tx)))
    assert(not str_eq(c, tls_client_handshake_traffic_secret_hex(hs, "other")))
}

fn TestTlsAppTrafficSecrets() {
    // Test-vector master secret → c/s ap traffic (distinct from hs traffic).
    let ms = "fedcba9876543210fedcba9876543210"
    let tx = ch_sh_seed()
    let c = tls_client_application_traffic_secret_hex(ms, tx)
    let s = tls_server_application_traffic_secret_hex(ms, tx)
    assert_eq(len(c), 64)
    assert_eq(len(s), 64)
    assert(not str_eq(c, s))
    assert(str_eq(c, tls_derive_secret_hex(ms, "c ap traffic", tx)))
    assert(not str_eq(c, tls_client_handshake_traffic_secret_hex(ms, tx)))
    assert(str_eq(c, tls_client_application_traffic_secret_hex(ms, tx)))
}

fn TestTlsHsState() {
    // 1-RTT client SM: start→wait_sh→wait_ee→wait_cert→wait_cv→wait_finished→app
    let cr = "0123456789abcdef0123456789abcdef"
    let sr = "fedcba9876543210fedcba9876543210"
    let _ = tls_hs_reset()
    assert_eq(tls_hs_state(), 0)
    assert_eq(tls_hs_is_app(), 0)
    assert_eq(tls_hs_advance(tls_client_hello(cr)), 1)
    assert_eq(tls_hs_advance(tls_server_hello(sr)), 2)
    assert_eq(tls_hs_advance(tls_encrypted_extensions()), 3)
    assert_eq(tls_hs_advance(tls_certificate("DER")), 4)
    assert_eq(tls_hs_advance(tls_certificate_verify(1027, "sig")), 5)
    assert_eq(tls_hs_advance(tls_finished("verifydata")), 6)
    assert_eq(tls_hs_is_app(), 1)
    // Wrong order rejected
    let _ = tls_hs_reset()
    assert_eq(tls_hs_advance(tls_server_hello(sr)), -1)
    assert_eq(tls_hs_state(), 0)
}

fn TestTlsHsSession() {
    // Session: wire CH/SH advances SM and accumulates transcript automatically.
    let cr = "0123456789abcdef0123456789abcdef"
    let sr = "fedcba9876543210fedcba9876543210"
    let key = "0123456789abcdef0123456789abcdef"
    let _ = tls_hs_session_reset()
    assert_eq(tls_hs_state(), 0)
    assert_eq(tls_transcript_len(), 0)
    assert_eq(tls_hs_session_client_hello(cr), 1)
    assert_eq(tls_hs_state(), 1)
    assert_eq(tls_transcript_len(), len(tls_client_hello(cr)))
    assert_eq(tls_hs_session_server_hello(sr), 2)
    assert_eq(tls_hs_state(), 2)
    let via = tls_hs_session_finished_hex(key)
    let direct = tls_finished_verify_data_hex(key, tls_client_hello(cr) + tls_server_hello(sr))
    assert(str_eq(via, direct))
    // Continue through EE…Finished via dedicated helpers
    assert_eq(tls_hs_session_encrypted_extensions(), 3)
    assert_eq(tls_hs_session_certificate("DER"), 4)
    assert_eq(tls_hs_session_certificate_verify(1027, "sig"), 5)
    assert_eq(tls_hs_session_finished(key, ""), 6)
    assert_eq(tls_hs_is_app(), 1)
    let _ = tls_hs_session_reset()
    assert_eq(tls_transcript_len(), 0)
}
