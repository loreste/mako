// map[K][]Option[T] / map[K][]Result[T,E] — bag-element slices as map values
// (zero-cost monomorphs; no runtime tax beyond the map itself).

struct Point {
    x: int
    y: int
}

fn TestMapStringOptionIntSlice() {
    let mut m = make(map[string][]Option[int])
    m["a"] = [Some(1), None, Some(3)]
    m["b"] = [None]
    assert_eq(len(m), 2)
    assert_eq(len(m["a"]), 3)
    match m["a"][0] {
        Some(v) => assert_eq(v, 1),
        None => assert(false),
    }
    match m["a"][1] {
        Some(_) => assert(false),
        None => assert(true),
    }
    match m["a"][2] {
        Some(v) => assert_eq(v, 3),
        None => assert(false),
    }
    assert(has(m, "a"))
    // missing key → empty slice
    assert_eq(len(m["missing"]), 0)
    delete(m, "b")
    assert(not has(m, "b"))
}

fn TestMapIntResultStringSlice() {
    let mut m = make(map[int][]Result[string, string])
    m[1] = [Ok("yes"), Err("no")]
    match m[1][0] {
        Ok(s) => assert_eq_str(s, "yes"),
        Err(_) => assert(false),
    }
    match m[1][1] {
        Ok(_) => assert(false),
        Err(e) => assert_eq_str(e, "no"),
    }
}

fn TestMapOptionStructSlice() {
    let mut m = make(map[string][]Option[Point])
    m["p"] = [Some(Point { x: 1, y: 2 }), None]
    match m["p"][0] {
        Some(pt) => {
            assert_eq(pt.x, 1)
            assert_eq(pt.y, 2)
        },
        None => assert(false),
    }
}

fn TestMapStructKeyOptionSlice() {
    let mut m = make(map[Point][]Option[int])
    let k = Point { x: 0, y: 0 }
    m[k] = [Some(9), None]
    match m[k][0] {
        Some(v) => assert_eq(v, 9),
        None => assert(false),
    }
    assert(has(m, k))
}

fn TestMapOptionSliceHelpers() {
    let mut m = make(map[string][]Option[int])
    m["a"] = [Some(1), Some(2)]
    m["b"] = [None]
    let ks = maps_keys(m)
    assert_eq(len(ks), 2)
    let vs = maps_values(m)
    assert_eq(len(vs), 2)
    let c = maps_clone(m)
    assert_eq(maps_equal(m, c), 1)
    // mutate clone
    c["a"] = [Some(99)]
    assert_eq(maps_equal(m, c), 0)
    maps_clear(c)
    assert_eq(len(c), 0)
    assert_eq(len(m), 2)
}

fn TestMapResultSliceHelpers() {
    let mut m = make(map[int][]Result[int, string])
    m[1] = [Ok(1), Err("e")]
    let c = maps_clone(m)
    assert_eq(maps_equal(m, c), 1)
}

fn TestMapOptionSliceAppend() {
    let mut m = make(map[string][]Option[int])
    let mut row = make([]Option[int], 0, 4)
    row = append(row, Some(1))
    row = append(row, None)
    m["x"] = row
    assert_eq(len(m["x"]), 2)
    match m["x"][1] {
        Some(_) => assert(false),
        None => assert(true),
    }
}
