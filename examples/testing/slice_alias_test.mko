// Regression: copying a struct with an owned slice field must deep-copy that
// field. Growing append consumes its owned backing allocation; a shallow copy
// would therefore dangle and double-free on the next append (regression from
// real xid_status-style handling).

struct Box {
    xs: []int
}

fn grow(mut b: Box, n: int) -> Box {
    var i = 0
    while i < n {
        b.xs = append(b.xs, i)
        i++
    }
    return b
}

func TestSliceAliasNoDoubleFree() {
    // Start with a small backing so appends force several grows.
    var a = Box{ xs: make([]int, 0, 2) }
    a.xs = append(a.xs, 100)

    // Copy the struct by value — b.xs receives independent owned storage.
    var b = a

    // Grow both through many reallocations. The old buffers must stay valid.
    a = grow(a, 50)
    b = grow(b, 50)

    // Both independent now; verify contents and lengths.
    assert_eq(len(a.xs), 51)
    assert_eq(len(b.xs), 51)
    assert_eq(a.xs[0], 100)
    assert_eq(b.xs[0], 100)
    assert_eq(a.xs[50], 49)
    assert_eq(b.xs[50], 49)
}
