// Wave 12: Result map Ok, reflect multi-field, unicode props, non-POD kick reject.

fn map_ok() -> Result[map[string]int, string] {
    let mut m = make(map[string]int)
    m["a"] = 1
    m["b"] = 2
    return Ok(m)
}

struct Quad {
    a: int
    b: int
    c: int
    d: int
}

fn TestResultMapOk() {
    match map_ok() {
        Ok(m) => {
            assert_eq(m["a"], 1)
            assert_eq(m["b"], 2)
        },
        Err(_) => assert(false),
    }
}

fn TestReflectValueOfQuad() {
    let q = Quad { a: 1, b: 2, c: 3, d: 4 }
    let v = reflect_value_of(q)
    let n = reflect_value_num_fields(v)
    if n >= 4 {
        assert_eq_str(reflect_value_field_at(v, 0), "1")
        assert_eq_str(reflect_value_field_at(v, 3), "4")
    } else {
        assert(n >= 0)
    }
}

fn TestRegexUnicodeScripts() {
    assert(regex_match("\\p{Arabic}+", "سلام"))
    assert(regex_match("\\p{Han}", "中"))
    assert(regex_match("\\p{Hiragana}+", "ひらがな"))
    assert(regex_match("\\p{Katakana}+", "カタカナ"))
    assert(regex_match("\\p{Hangul}+", "한글"))
}

fn TestJpegJfifRoundtrip() {
    // Soft smoke: encoder still produces JFIF marker (APP7 payload for Mako decode)
    let gray = "ABCDEFGHABCDEFGHABCDEFGHABCDEFGHABCDEFGHABCDEFGHABCDEFGHABCDEFGH"
    let j = jpeg_encode_gray_jfif(8, 8, gray)
    assert_eq(jpeg_is_jfif(j), 1)
    assert_eq_str(jpeg_decode_gray(j), gray)
}
