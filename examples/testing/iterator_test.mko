// Iterator protocol tests — mut-self `for` advances the binding in place.

struct Range {
    current: int
    max: int
}

fn new_range(max: int) -> Range {
    return Range { current: 0, max: max }
}

on Range {
    // Advancing iterator: for-loops pass &self when next takes mut self.
    fn next(mut self) -> Option[int] {
        if self.current >= self.max {
            return None
        }
        let v = self.current
        self.current = self.current + 1
        return Some(v)
    }
}

fn TestIteratorNext() {
    let mut r = new_range(3)
    let opt = r.next()
    match opt {
        Some(v) => assert_eq(v, 0),
        None => assert(false),
    }
    assert_eq(r.current, 1)
}

fn TestIteratorManualLoop() {
    let mut r = new_range(5)
    let mut sum = 0
    while true {
        match r.next() {
            Some(v) => {
                sum = sum + v
            },
            None => {
                break
            },
        }
    }
    assert_eq(sum, 10)
    assert_eq(r.current, 5)
}

fn TestForMutNext() {
    let mut r = new_range(5)
    let mut sum = 0
    for v in r {
        sum = sum + v
    }
    assert_eq(sum, 10)
    assert_eq(r.current, 5)
}

fn TestForMutNextEmpty() {
    let mut r = new_range(0)
    let mut n = 0
    for _ in r {
        n = n + 1
    }
    assert_eq(n, 0)
    assert_eq(r.current, 0)
}

fn TestIteratorTypeCheck() {
    let mut r = new_range(1)
    assert_eq(r.max, 1)
}
