// const fn — compile-time evaluation for sizes and configs.

const fn double(x: int) -> int {
    return x * 2
}

const fn area(w: int, h: int) -> int {
    let a = w * h
    return a
}

const MAX_BUF = double(512)
const TILE = area(16, 16)

fn TestConstFnFold() {
    // Folded at compile time into integer literals
    assert_eq(MAX_BUF, 1024)
    assert_eq(TILE, 256)
    assert_eq(double(21), 42)
    assert_eq(area(3, 7), 21)
}

fn TestConstFnAsArraySize() {
    // Using const values in ordinary arithmetic still works
    let n = MAX_BUF + TILE
    assert_eq(n, 1280)
}

const fn abs_const(x: int) -> int {
    if x < 0 {
        return 0 - x
    } else {
        return x
    }
}

const fn max_const(a: int, b: int) -> int {
    if a >= b {
        return a
    }
    return b
}

const fn clamp_const(x: int, lo: int, hi: int) -> int {
    if x < lo {
        return lo
    } else {
        if x > hi {
            return hi
        } else {
            return x
        }
    }
}

const A_ABS = abs_const(0 - 7)
const A_MAX = max_const(3, 9)
const A_CL = clamp_const(50, 0, 10)

fn TestConstFnIf() {
    assert_eq(A_ABS, 7)
    assert_eq(A_MAX, 9)
    assert_eq(A_CL, 10)
    assert_eq(abs_const(4), 4)
    assert_eq(max_const(1, 2), 2)
    assert_eq(clamp_const(0 - 1, 0, 5), 0)
    // if-expression form
    assert_eq(if 1 < 2 { 10 } else { 20 }, 10)
}

// --- Depth seed: match + while (bounded) ---

const fn classify(n: int) -> int {
    return match n {
        0 => 100,
        1 | 2 => 200,
        _ => -1,
    }
}

const fn sign_const(n: int) -> int {
    return match n {
        0 => 0,
        x => if x > 0 { 1 } else { 0 - 1 },
    }
}

const fn sum_to(n: int) -> int {
    let mut i = 0
    let mut s = 0
    while i < n {
        s = s + i
        i = i + 1
    }
    return s
}

const fn pow2(n: int) -> int {
    let mut i = 0
    let mut p = 1
    while i < n {
        p = p * 2
        i = i + 1
    }
    return p
}

const C_CLASS0 = classify(0)
const C_CLASS1 = classify(1)
const C_CLASS9 = classify(9)
const C_SIGN = sign_const(0 - 5)
const C_SUM = sum_to(5)
const C_POW = pow2(10)

fn TestConstFnMatch() {
    assert_eq(C_CLASS0, 100)
    assert_eq(C_CLASS1, 200)
    assert_eq(classify(2), 200)
    assert_eq(C_CLASS9, -1)
    assert_eq(C_SIGN, 0 - 1)
    assert_eq(sign_const(3), 1)
    assert_eq(sign_const(0), 0)
}

fn TestConstFnWhile() {
    // 0+1+2+3+4 = 10
    assert_eq(C_SUM, 10)
    assert_eq(sum_to(1), 0)
    assert_eq(sum_to(0), 0)
    assert_eq(C_POW, 1024)
    assert_eq(pow2(0), 1)
    assert_eq(pow2(3), 8)
}

// --- Depth seed: for count + C-style for ---

const fn sum_for(n: int) -> int {
    let mut s = 0
    for i in n {
        s = s + i
    }
    return s
}

const fn sum_range_for(n: int) -> int {
    let mut s = 0
    for i in range n {
        s = s + i
    }
    return s
}

const fn sum_cfor(n: int) -> int {
    let mut s = 0
    for i := 0; i < n; i = i + 1 {
        s = s + i
    }
    return s
}

const fn fact_for(n: int) -> int {
    let mut p = 1
    for i in n {
        p = p * (i + 1)
    }
    return p
}

const C_FOR = sum_for(5)
const C_RFOR = sum_range_for(5)
const C_CFOR = sum_cfor(5)
const C_FACT = fact_for(5)

fn TestConstFnFor() {
    assert_eq(C_FOR, 10)
    assert_eq(C_RFOR, 10)
    assert_eq(C_CFOR, 10)
    assert_eq(sum_for(0), 0)
    assert_eq(sum_for(1), 0)
    assert_eq(sum_cfor(4), 6)
    // 1*2*3*4*5
    assert_eq(C_FACT, 120)
    assert_eq(fact_for(0), 1)
}

// --- Depth seed: break / continue in const loops ---

const fn sum_until(n: int, stop: int) -> int {
    let mut s = 0
    for i in n {
        if i == stop {
            break
        }
        s = s + i
    }
    return s
}

const fn sum_odds(n: int) -> int {
    let mut s = 0
    for i in n {
        if i % 2 == 0 {
            continue
        }
        s = s + i
    }
    return s
}

const fn sum_odds_cfor(n: int) -> int {
    let mut s = 0
    for i := 0; i < n; i = i + 1 {
        if i % 2 == 0 {
            continue
        }
        s = s + i
    }
    return s
}

const fn first_ge(n: int, thr: int) -> int {
    let mut i = 0
    while i < n {
        if i >= thr {
            break
        }
        i = i + 1
    }
    return i
}

const C_BRK = sum_until(10, 5)
const C_ODD = sum_odds(6)
const C_ODDC = sum_odds_cfor(6)
const C_FGE = first_ge(20, 7)

fn TestConstFnBreakContinue() {
    // 0+1+2+3+4
    assert_eq(C_BRK, 10)
    assert_eq(sum_until(10, 0), 0)
    // 1+3+5
    assert_eq(C_ODD, 9)
    assert_eq(C_ODDC, 9)
    assert_eq(sum_odds(1), 0)
    assert_eq(C_FGE, 7)
    assert_eq(first_ge(3, 10), 3)
}

// --- Const string seed: literals, +, str_len, == ---

const GREET = "hi"
const BANG = "!"
const FULL = "hi" + "!"
const GREET2 = GREET + BANG
const GLEN = str_len(GREET)
const FLEN = str_len(FULL)
const SAME = GREET == "hi"
const DIFF = FULL != "hi"

fn TestConstString() {
    assert_eq(GLEN, 2)
    assert_eq(FLEN, 3)
    assert_eq(str_len(GREET2), 3)
    // Equality folds to int 0/1 at const time
    assert_eq(SAME, 1)
    assert_eq(DIFF, 1)
    assert(GREET == "hi")
    assert(FULL == "hi!")
    assert(GREET2 == FULL)
    // Runtime use of const string value
    assert_eq_str(GREET, "hi")
    assert_eq_str(FULL, "hi!")
}

// --- Const fn string params / returns ---

const fn shout(s: string) -> string {
    return s + "!"
}

const fn greet(name: string) -> string {
    let prefix = "hi "
    return prefix + name
}

const fn pick(n: int) -> string {
    if n > 0 {
        return "yes"
    }
    return "no"
}

const fn len_greet(name: string) -> int {
    let g = "hi " + name
    return str_len(g)
}

const C_SHOUT = shout("hey")
const C_GREET = greet("mako")
const C_PICK = pick(1)
const C_PICK0 = pick(0)
const C_LG = len_greet("ab")

fn TestConstFnString() {
    assert_eq_str(C_SHOUT, "hey!")
    assert_eq_str(C_GREET, "hi mako")
    assert_eq_str(C_PICK, "yes")
    assert_eq_str(C_PICK0, "no")
    assert_eq(C_LG, 5)
    assert_eq_str(shout("x"), "x!")
    assert_eq(len_greet("z"), 4)
    assert_eq_str(greet("you"), "hi you")
}

// Const string indexing: s[i] folds to the byte value 0..255.
const C_FB = "AB"[0]
const C_SB = "AB"[1]
const C_HI0 = "hi"[0]

fn TestConstStrIndex() {
    assert_eq(C_FB, 65)
    assert_eq(C_SB, 66)
    assert_eq(C_HI0, 104)
    assert_eq("mako"[0], 109)
}
