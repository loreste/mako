// C-style for init; cond; post. Differentially vs C.
fn main() {
    var s = 0
    for i := 0; i < 5; i = i + 1 {
        s = s + i
    }
    print_int(s)

    var t = 0
    for j := 0; j < 10; j = j + 1 {
        if j == 2 {
            continue
        }
        if j == 5 {
            break
        }
        t = t + j
    }
    print_int(t)
}
