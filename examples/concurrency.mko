// First-class concurrency — structured crew (no orphan tasks).
// Speed path: native threads via runtime; join before crew ends.

fn work(n: int) -> int {
    return n * n
}

fn main() {
    crew t {
        let a = t.kick(work(7))
        let b = t.kick(work(9))
        let x = a.join()
        let y = b.join()
        print(x + y) // 49 + 81 = 130
    }
}
