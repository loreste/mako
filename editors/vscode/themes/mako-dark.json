{
  "name": "Mako Dark",
  "type": "dark",
  "colors": {
    "editor.background": "#1a1b26",
    "editor.foreground": "#c0caf5",
    "editorCursor.foreground": "#7aa2f7",
    "editor.lineHighlightBackground": "#1e2030",
    "editor.selectionBackground": "#33467c",
    "editorLineNumber.foreground": "#3b4261",
    "editorLineNumber.activeForeground": "#737aa2",
    "sideBar.background": "#16161e",
    "sideBar.foreground": "#c0caf5",
    "activityBar.background": "#16161e",
    "statusBar.background": "#16161e",
    "tab.activeBackground": "#1a1b26",
    "tab.inactiveBackground": "#16161e",
    "titleBar.activeBackground": "#16161e",
    "terminal.background": "#1a1b26",
    "terminal.foreground": "#c0caf5"
  },
  "tokenColors": [
    {
      "name": "Comments — subtle gray",
      "scope": ["comment", "comment.line", "comment.block"],
      "settings": { "foreground": "#565f89", "fontStyle": "italic" }
    },
    {
      "name": "Strings — green",
      "scope": ["string", "string.quoted", "string.quoted.double"],
      "settings": { "foreground": "#9ece6a" }
    },
    {
      "name": "String escapes — bright green",
      "scope": ["constant.character.escape"],
      "settings": { "foreground": "#73daca", "fontStyle": "bold" }
    },
    {
      "name": "Format specifiers in strings",
      "scope": ["constant.character.escape.format"],
      "settings": { "foreground": "#7dcfff" }
    },
    {
      "name": "Import paths — green",
      "scope": ["string.quoted.double.import"],
      "settings": { "foreground": "#9ece6a" }
    },
    {
      "name": "Numbers — orange",
      "scope": ["constant.numeric", "constant.numeric.integer", "constant.numeric.float", "constant.numeric.hex", "constant.numeric.binary"],
      "settings": { "foreground": "#ff9e64" }
    },
    {
      "name": "Booleans — orange",
      "scope": ["constant.language.boolean"],
      "settings": { "foreground": "#ff9e64" }
    },
    {
      "name": "Control flow keywords — magenta/purple",
      "scope": ["keyword.control.flow", "keyword.control.import"],
      "settings": { "foreground": "#bb9af7" }
    },
    {
      "name": "Declarations — blue",
      "scope": ["keyword.declaration", "keyword.declaration.function", "keyword.declaration.struct", "keyword.declaration.enum", "keyword.declaration.actor", "keyword.declaration.interface"],
      "settings": { "foreground": "#7aa2f7" }
    },
    {
      "name": "Concurrency keywords — cyan",
      "scope": ["keyword.control.concurrency"],
      "settings": { "foreground": "#7dcfff", "fontStyle": "bold" }
    },
    {
      "name": "Memory keywords — red/coral",
      "scope": ["keyword.control.memory"],
      "settings": { "foreground": "#f7768e" }
    },
    {
      "name": "Ok/Err/Some/None — teal",
      "scope": ["keyword.other"],
      "settings": { "foreground": "#73daca" }
    },
    {
      "name": "Logical operators (and/or/not)",
      "scope": ["keyword.operator.logical"],
      "settings": { "foreground": "#bb9af7" }
    },
    {
      "name": "Operators — light blue",
      "scope": ["keyword.operator", "keyword.operator.arrow", "keyword.operator.fat-arrow", "keyword.operator.comparison", "keyword.operator.assignment", "keyword.operator.arithmetic", "keyword.operator.bitwise", "keyword.operator.question"],
      "settings": { "foreground": "#89ddff" }
    },
    {
      "name": "Function definitions — bright yellow",
      "scope": ["entity.name.function.definition"],
      "settings": { "foreground": "#e0af68", "fontStyle": "bold" }
    },
    {
      "name": "Function calls — yellow",
      "scope": ["entity.name.function.call", "entity.name.function.method", "entity.name.function.associated"],
      "settings": { "foreground": "#e0af68" }
    },
    {
      "name": "Type/struct/enum names — bright cyan",
      "scope": ["entity.name.type", "entity.name.type.struct", "entity.name.type.enum", "entity.name.type.actor", "entity.name.type.interface"],
      "settings": { "foreground": "#2ac3de", "fontStyle": "bold" }
    },
    {
      "name": "Primitive types — cyan",
      "scope": ["support.type.primitive"],
      "settings": { "foreground": "#2ac3de" }
    },
    {
      "name": "Built-in types — teal",
      "scope": ["support.type.builtin", "support.type.user", "support.type.generic"],
      "settings": { "foreground": "#73daca" }
    },
    {
      "name": "Enum members/variants — peach",
      "scope": ["variable.other.enummember"],
      "settings": { "foreground": "#ff9e64" }
    },
    {
      "name": "Attributes (#[derive(json)]) — gray/lavender",
      "scope": ["meta.attribute", "entity.other.attribute-name"],
      "settings": { "foreground": "#9aa5ce" }
    },
    {
      "name": "Attribute values",
      "scope": ["string.unquoted.attribute-value"],
      "settings": { "foreground": "#9ece6a" }
    },
    {
      "name": "self keyword — red italic",
      "scope": ["variable.language.self"],
      "settings": { "foreground": "#f7768e", "fontStyle": "italic" }
    },
    {
      "name": "Discard underscore",
      "scope": ["variable.language.discard"],
      "settings": { "foreground": "#565f89" }
    },
    {
      "name": "Namespace from alias",
      "scope": ["entity.name.namespace"],
      "settings": { "foreground": "#7dcfff" }
    },
    {
      "name": "Punctuation — subtle",
      "scope": ["punctuation.separator", "punctuation.terminator", "punctuation.section"],
      "settings": { "foreground": "#a9b1d6" }
    }
  ]
}
