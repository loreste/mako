        owned_ir.instructions[3].op != IR_CALL or owned_ir.instructions[3].left >= 0 or
        owned_ir.instructions[3].aux != 0 or len(owned_ir.call_sites) != 1 or
        owned_ir.call_sites[0].callee_item != 0 or owned_ir.call_sites[0].argument_count != 0 or
        len(owned_ir.call_arguments) != 0 or owned_ir.instructions[4].op != IR_MOVE or
        owned_ir.instructions[4].left != owned_ir.instructions[3].result or
        owned_ir.instructions[5].op != IR_RETURN or
        owned_ir.instructions[5].left != owned_ir.instructions[4].result { return false }
    let owned_verified = verify_typed_ir(
        owned_ir.functions, owned_ir.blocks, owned_ir.instructions, owned_ir.constants,
        owned_ir.successors, owned_ir.call_sites, owned_ir.call_arguments, owned_ir.value_count
    )
    if not owned_verified.ok or owned_verified.checked_values != 4 { return false }

    let multi_source = "fn join_values(prefix: string, suffix: string) -> string {\nreturn prefix + suffix\n}\nfn use_join() -> string {\nreturn join_values(\"mako\", \"lang\")\n}"
    let multi_lexed = lex_source(multi_source)
