        len(owned_argument_ir.functions) != 2 or len(owned_argument_ir.blocks) != 4 or
        len(owned_argument_ir.instructions) != 14 or owned_argument_ir.value_count != 7 or
        len(owned_argument_ir.call_sites) != 1 or len(owned_argument_ir.call_arguments) != 1 or
        owned_argument_ir.instructions[7].op != IR_CLONE or
        owned_argument_ir.instructions[8].op != IR_CALL or
        owned_argument_ir.call_arguments[0] != owned_argument_ir.instructions[7].result or
        owned_argument_ir.instructions[9].op != IR_DROP or
        owned_argument_ir.instructions[9].left != owned_argument_ir.instructions[5].result or
        owned_argument_ir.instructions[12].op != IR_DROP or
        owned_argument_ir.instructions[12].left != owned_argument_ir.instructions[5].result {
        return false
    }
    let owned_argument_verified = verify_typed_ir(
        owned_argument_ir.functions, owned_argument_ir.blocks, owned_argument_ir.instructions,
        owned_argument_ir.constants, owned_argument_ir.successors, owned_argument_ir.call_sites,
        owned_argument_ir.call_arguments, owned_argument_ir.value_count
    )
    if not owned_argument_verified.ok or owned_argument_verified.checked_values != 7 { return false }

    let held_argument_source = "fn inspect_held(label: string) -> int {\nreturn 1\n}\nfn choose_held(flag: bool) -> int {\nhold let label = \"mako\"\nif flag {\nreturn inspect_held(label)\n}\nreturn 0\n}"
    let held_argument_lexed = lex_source(held_argument_source)
    if not held_argument_lexed.ok { return false }
    let held_argument = parse_frontend(held_argument_source, held_argument_lexed.tokens)
    if not held_argument.ok { return false }
    let held_argument_ir = lower_typed_ir(
        held_argument_source, held_argument_lexed.tokens, held_argument.items,
        held_argument.signatures, held_argument.statements, held_argument.statement_edges,
        held_argument.expressions, held_argument.expression_types, held_argument.locals,
        held_argument.local_types, held_argument.expression_locals, held_argument.symbols,
        held_argument.expression_symbols
    )
    if not held_argument_ir.ok or held_argument_ir.skipped_functions != 0 or
        len(held_argument_ir.functions) != 2 or len(held_argument_ir.blocks) != 4 or
        len(held_argument_ir.instructions) != 12 or held_argument_ir.value_count != 6 or
        len(held_argument_ir.call_sites) != 1 or len(held_argument_ir.call_arguments) != 1 or
        held_argument_ir.instructions[7].op != IR_CALL or
        held_argument_ir.call_arguments[0] != held_argument_ir.instructions[5].result or
        held_argument_ir.instructions[8].op != IR_RETURN or
        held_argument_ir.instructions[9].op != IR_CONST or
        held_argument_ir.instructions[10].op != IR_DROP or
        held_argument_ir.instructions[10].left != held_argument_ir.instructions[5].result or
        held_argument_ir.instructions[11].op != IR_RETURN { return false }
    let held_argument_verified = verify_typed_ir(
        held_argument_ir.functions, held_argument_ir.blocks, held_argument_ir.instructions,
        held_argument_ir.constants, held_argument_ir.successors, held_argument_ir.call_sites,
        held_argument_ir.call_arguments, held_argument_ir.value_count
    )
    return held_argument_verified.ok and held_argument_verified.checked_values == 6
}

fn typed_ir_call_verifier_smoke_test() -> bool {
    let mut functions: []IrFunction = []
    let mut blocks: []IrBlock = []
    let mut instructions: []IrInstruction = []
    functions = append(functions, IrFunction {
        item: 0, entry_block: 0, block_count: 1,
        parameter_count: 1, value_start: 0, value_count: 2,
    })
    instructions = append(instructions, IrInstruction {
        op: IR_PARAM, result: 0, type_kind: SEM_STRING,
        left: -1, right: -1, aux: 0, token: 0,
    })
    instructions = append(instructions, IrInstruction {
        op: IR_CALL, result: 1, type_kind: SEM_STRING,
        left: -1, right: -1, aux: 0, token: 0,
    })
    instructions = append(instructions, IrInstruction {
        op: IR_RETURN, result: -1, type_kind: SEM_STRING,
        left: 1, right: -1, aux: -1, token: 0,
    })
    blocks = append(blocks, IrBlock {
        function: 0, instruction_start: 0, instruction_count: 3,
        terminator: 2, successor_start: 0, successor_count: 0,
    })
    let verified = verify_typed_ir(
        functions, blocks, instructions, make([]IrConstant, 0, 0), make([]int, 0, 0),
        make([]IrCallSite, 0, 0), make([]int, 0, 0), 2
    )
    return not verified.ok and verified.error == "IR call has invalid callee or argument layout"
}
