        multi_source, multi_lexed.tokens, multi.items, multi.signatures, multi.statements,
        multi.statement_edges, multi.expressions, multi.expression_types, multi.locals,
        multi.local_types, multi.expression_locals, multi.symbols, multi.expression_symbols
    )
    if not multi_ir.ok or len(multi_ir.instructions) != 12 or multi_ir.value_count != 8 or
        len(multi_ir.call_sites) != 1 or len(multi_ir.call_arguments) != 2 or
        multi_ir.call_sites[0].callee_item != 0 or multi_ir.call_sites[0].argument_start != 0 or
        multi_ir.call_sites[0].argument_count != 2 or multi_ir.call_arguments[0] != 4 or
        multi_ir.call_arguments[1] != 5 or multi_ir.instructions[9].op != IR_CALL or
