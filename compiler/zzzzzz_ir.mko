fn typed_ir_ownership_verifier_smoke_test() -> bool {
    let mut functions: []IrFunction = []
    let mut blocks: []IrBlock = []
    let mut instructions: []IrInstruction = []
    functions = append(functions, IrFunction {
        item: 0, entry_block: 0, block_count: 1,
        parameter_count: 1, value_start: 0, value_count: 1,
    })
    instructions = append(instructions, IrInstruction {
        op: IR_PARAM, result: 0, type_kind: SEM_ARRAY_INT,
        left: -1, right: -1, aux: 0, token: 0,
    })
    instructions = append(instructions, IrInstruction {
        op: IR_DROP, result: -1, type_kind: SEM_ARRAY_INT,
        left: 0, right: -1, aux: -1, token: 0,
    })
    instructions = append(instructions, IrInstruction {
        op: IR_DROP, result: -1, type_kind: SEM_ARRAY_INT,
        left: 0, right: -1, aux: -1, token: 0,
    })
    instructions = append(instructions, IrInstruction {
        op: IR_RETURN, result: -1, type_kind: SEM_UNKNOWN,
        left: -1, right: -1, aux: -1, token: 0,
    })
    blocks = append(blocks, IrBlock {
        function: 0, instruction_start: 0, instruction_count: 4,
        terminator: 3, successor_start: 0, successor_count: 0,
    })
    let double_drop = verify_typed_ir(
        functions, blocks, instructions, make([]IrConstant, 0, 0), make([]int, 0, 0),
        make([]IrCallSite, 0, 0), make([]int, 0, 0), 1
    )
    if double_drop.ok or double_drop.error != "IR owned value is dropped twice" { return false }

    functions = make([]IrFunction, 0, 0)
    blocks = make([]IrBlock, 0, 0)
    instructions = make([]IrInstruction, 0, 0)
    functions = append(functions, IrFunction {
        item: 0, entry_block: 0, block_count: 1,
        parameter_count: 1, value_start: 0, value_count: 3,
    })
    instructions = append(instructions, IrInstruction {
        op: IR_PARAM, result: 0, type_kind: SEM_ARRAY_INT,
        left: -1, right: -1, aux: 0, token: 0,
    })
    instructions = append(instructions, IrInstruction {
        op: IR_MOVE, result: 1, type_kind: SEM_ARRAY_INT,
        left: 0, right: -1, aux: -1, token: 0,
    })
    instructions = append(instructions, IrInstruction {
        op: IR_MOVE, result: 2, type_kind: SEM_ARRAY_INT,
        left: 0, right: -1, aux: -1, token: 0,
    })
    instructions = append(instructions, IrInstruction {
        op: IR_RETURN, result: -1, type_kind: SEM_ARRAY_INT,
        left: 2, right: -1, aux: -1, token: 0,
    })
    blocks = append(blocks, IrBlock {
        function: 0, instruction_start: 0, instruction_count: 4,
        terminator: 3, successor_start: 0, successor_count: 0,
    })
    let use_after_move = verify_typed_ir(
        functions, blocks, instructions, make([]IrConstant, 0, 0), make([]int, 0, 0),
        make([]IrCallSite, 0, 0), make([]int, 0, 0), 3
    )
    return not use_after_move.ok and use_after_move.error == "IR instruction uses consumed owned value"
}

fn typed_ir_call_smoke_test() -> bool {
    let source = "fn identity(value: int) -> int {\nreturn value\n}\nfn use_identity() -> int {\nreturn identity(1)\n}"
    let lexed = lex_source(source)
    if not lexed.ok { return false }
    let parsed = parse_frontend(source, lexed.tokens)
    if not parsed.ok { return false }
    let ir = lower_typed_ir(
        source, lexed.tokens, parsed.items, parsed.signatures, parsed.statements,
        parsed.statement_edges, parsed.expressions, parsed.expression_types, parsed.locals,
        parsed.local_types, parsed.expression_locals, parsed.symbols, parsed.expression_symbols
    )
    if not ir.ok or len(ir.functions) != 2 or len(ir.blocks) != 2 or
        len(ir.instructions) != 5 or ir.value_count != 3 { return false }
    let verified = verify_typed_ir(
        ir.functions, ir.blocks, ir.instructions, ir.constants, ir.successors,
        ir.call_sites, ir.call_arguments, ir.value_count
    )
    if not verified.ok or verified.checked_values != 3 { return false }
    if ir.instructions[2].op != IR_CONST or ir.instructions[3].op != IR_CALL or
        ir.instructions[3].left >= 0 or ir.instructions[3].right >= 0 or
        ir.instructions[3].aux != 0 or len(ir.call_sites) != 1 or len(ir.call_arguments) != 1 or
        ir.call_sites[0].callee_item != 0 or ir.call_sites[0].argument_start != 0 or
        ir.call_sites[0].argument_count != 1 or
        ir.call_arguments[0] != ir.instructions[2].result { return false }

    let owned_source = "fn make_label() -> string {\nreturn \"mako\"\n}\nfn use_label() -> string {\nreturn make_label()\n}"
    let owned_lexed = lex_source(owned_source)
    if not owned_lexed.ok { return false }
    let owned = parse_frontend(owned_source, owned_lexed.tokens)
    if not owned.ok { return false }
