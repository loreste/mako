    if not cfg_ir.ok or len(cfg_ir.blocks) != 4 or len(cfg_ir.instructions) != 10 or
        cfg_ir.value_count != 4 or cfg_ir.instructions[4].op != IR_DROP or
        cfg_ir.instructions[4].left != 2 or cfg_ir.instructions[5].op != IR_JUMP or
        cfg_ir.instructions[5].left != 1 or cfg_ir.instructions[6].op != IR_DROP or
        cfg_ir.instructions[6].left != 1 or cfg_ir.instructions[7].op != IR_JUMP or
        cfg_ir.instructions[7].left != 2 or cfg_ir.instructions[8].op != IR_BLOCK_PARAM or
