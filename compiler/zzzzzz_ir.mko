    if not multi_verified.ok or multi_verified.checked_values != 8 { return false }

    let clone_source = "fn keep_label(label: string) -> string {\nreturn label\n}\nfn reuse_label() -> string {\nlet label = \"mako\"\nlet copy = keep_label(label)\nreturn label\n}"
    let clone_lexed = lex_source(clone_source)
