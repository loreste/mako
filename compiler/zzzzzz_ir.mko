        owned_source, owned_lexed.tokens, owned.items, owned.signatures, owned.statements,
        owned.statement_edges, owned.expressions, owned.expression_types, owned.locals,
        owned.local_types, owned.expression_locals, owned.symbols, owned.expression_symbols
