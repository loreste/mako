fn digest_sha256(s: string) -> string { return sha256(s) }
fn digest_sha1(s: string) -> string { return sha1(s) }
fn digest_sha512(s: string) -> string { return sha512(s) }
fn hmac(key: string, msg: string) -> string { return hmac_sha256(key, msg) }
fn rand_bytes(n: int) -> string { return random_bytes(n) }
fn rand_int(lo: int, hi: int) -> int { return random_int(lo, hi) }
fn eq(a: string, b: string) -> int { return const_eq(a, b) }
fn aead_ok() -> int { return aead_available() }

// Password hashing — Argon2id (OWASP-recommended), backed by OpenSSL.
// `password_hash` returns a self-describing PHC string; `password_verify`
// checks a password against it in constant time.
fn password_hash(password: string) -> string { return argon2id_hash(password) }
fn password_verify(hash: string, password: string) -> int { return argon2id_verify(hash, password) }
fn password_hashing_ok() -> int { return argon2_available() }

// bcrypt (`$2b$`) — for interop with existing bcrypt password stores. Needs
// libxcrypt (Linux); `bcrypt_ok` reports availability. Prefer Argon2id for new
// systems. `cost` is the work factor (4–31); 10–12 is typical.
fn bcrypt(password: string, cost: int) -> string { return bcrypt_hash(password, cost) }
fn bcrypt_check(hash: string, password: string) -> int { return bcrypt_verify(hash, password) }
fn bcrypt_ok() -> int { return bcrypt_available() }

// Key derivation — PBKDF2-HMAC-SHA256 (password, salt, iterations, key length).
// A building block for SCRAM-SHA-256 and legacy password KDFs.
fn pbkdf2(password: string, salt: string, iterations: int, dklen: int) -> string {
    return pbkdf2_sha256(password, salt, iterations, dklen)
}

// SCRAM-SHA-256 (RFC 5802 / RFC 7677) — the crypto core for Postgres-style
// challenge-response auth. `salt` is raw bytes (base64-decode the wire value
// first). Compose the AuthMessage yourself from the protocol strings:
//   auth = client_first_bare + "," + server_first + "," + client_final_no_proof
fn scram_salted_password(password: string, salt: string, iterations: int) -> string {
    return pbkdf2_sha256(password, salt, iterations, 32)
}
fn scram_client_key(salted: string) -> string { return hmac_sha256_raw(salted, "Client Key") }
fn scram_server_key(salted: string) -> string { return hmac_sha256_raw(salted, "Server Key") }
fn scram_stored_key(client_key: string) -> string { return sha256_raw(client_key) }
fn scram_client_signature(stored_key: string, auth: string) -> string {
    return hmac_sha256_raw(stored_key, auth)
}
fn scram_server_signature(server_key: string, auth: string) -> string {
    return hmac_sha256_raw(server_key, auth)
}
// Client side: proof = ClientKey XOR ClientSignature.
fn scram_client_proof(client_key: string, client_signature: string) -> string {
    return xor_bytes(client_key, client_signature)
}
// Server side: recover ClientKey from the proof and check it against StoredKey.
// Returns 1 when the client's proof is valid, else 0.
fn scram_verify_proof(stored_key: string, auth: string, client_proof: string) -> int {
    let sig = hmac_sha256_raw(stored_key, auth)
    let ck = xor_bytes(client_proof, sig)
    // Constant-time compare of derived StoredKey vs expected.
    if const_eq(sha256_raw(ck), stored_key) == 1 {
        return 1
    }
    return 0
}
fn aes_gcm_encrypt(key: string, nonce: string, pt: string, aad: string) -> string {
    return aes_gcm_seal(key, nonce, pt, aad)
}
fn aes_gcm_decrypt(key: string, nonce: string, sealed: string, aad: string) -> string {
    return aes_gcm_open(key, nonce, sealed, aad)
}

// Encryption at rest — random-nonce AES-GCM (nonce||ct||tag). Key is 16 bytes.
// Globals: seal_at_rest / open_at_rest / seal_file_at_rest / open_file_at_rest.
fn seal(key: string, plaintext: string, aad: string) -> string {
    return seal_at_rest(key, plaintext, aad)
}
fn open(key: string, sealed: string, aad: string) -> string {
    return open_at_rest(key, sealed, aad)
}

// SCRAM channel binding (RFC 5802 gs2-header + c= attribute).
// cbind_name "" or "n" → no binding; "tls-unique" → SCRAM-SHA-256-PLUS style.
// Globals: scram_gs2_header / scram_cbind_b64 / scram_client_final_without_proof.
fn scram_gs2(cbind_name: string) -> string {
    return scram_gs2_header(cbind_name)
}
fn scram_cbind(gs2_header: string, cbind_data: string) -> string {
    return scram_cbind_b64(gs2_header, cbind_data)
}
fn scram_client_final_bare(cbind_b64: string, nonce: string) -> string {
    return scram_client_final_without_proof(cbind_b64, nonce)
}
fn chacha_encrypt(key: string, nonce: string, pt: string, aad: string) -> string {
    return chacha20_poly1305_seal(key, nonce, pt, aad)
}
fn chacha_decrypt(key: string, nonce: string, sealed: string, aad: string) -> string {
    return chacha20_poly1305_open(key, nonce, sealed, aad)
}
